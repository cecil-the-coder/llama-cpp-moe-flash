+// I10b debug: SIGSEGV backtrace handler - installed at library load time.
+// Prints a stack trace to stderr (fd 2) so crash location is visible in
+// kubectl logs even if the process dies before compute_splits fires.
+#if defined(__linux__)
+#include <signal.h>
+#include <execinfo.h>
+#include <unistd.h>
+namespace {
+__attribute__((constructor))
+static void install_sigsegv_handler() {
+    struct sigaction sa;
+    sa.sa_flags = SA_RESETHAND;
+    sigemptyset(&sa.sa_mask);
+    sa.sa_handler = [](int) {
+        const char msg[] = "\n[CRASH] SIGSEGV in ggml-base -- backtrace:\n";
+        write(2, msg, sizeof(msg) - 1);
+        void * bt[64];
+        int n = backtrace(bt, 64);
+        backtrace_symbols_fd(bt, n, 2);
+        fsync(2);
+        _exit(139);
+    };
+    sigaction(SIGSEGV, &sa, nullptr);
+}
+} // namespace
+#endif
