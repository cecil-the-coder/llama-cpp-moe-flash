+#define QK_TQ2_KV 128
+
+// 2.125 bpw KV cache quantization
+typedef struct {
+    ggml_half d;        // scale: max_abs / 1.5
+    uint8_t   qs[32];   // 128 x 2-bit packed, 4 per byte
+} block_tq2_kv;
+static_assert(sizeof(block_tq2_kv) == 34, "wrong block_tq2_kv size");
+
 //
 // Super-block quantization structures
 //
diff --git a/ggml/src/ggml-quants.c b/ggml/src/ggml-quants.c
index cdaded8..e455793 100644
--- a/ggml/src/ggml-quants.c
+++ b/ggml/src/ggml-quants.c
@@ -2336,6 +2336,69 @@ void dequantize_row_tq2_0(const block_tq2_0 * GGML_RESTRICT x, float * GGML_REST
     }
 }
 
+
+// TQ2_KV: 2.125 bpw KV cache quantization (128-element block, symmetric 4-level)
+
+void quantize_row_tq2_kv_ref(const float * GGML_RESTRICT x, block_tq2_kv * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ2_KV == 0);
+    const int64_t nb = k / QK_TQ2_KV;
+
+    for (int64_t i = 0; i < nb; i++) {
+        float max_abs = 0.0f;
+
+        for (int j = 0; j < QK_TQ2_KV; j++) {
+            const float v = x[j];
+            // NaN/Inf guard: treat as 0
+            if (v == v && v != INFINITY && v != -INFINITY) {
+                const float av = fabsf(v);
+                if (av > max_abs) max_abs = av;
+            }
+        }
+
+        const float d = max_abs == 0.0f ? 1.0f : max_abs / 1.5f;
+        y[i].d = GGML_FP32_TO_FP16(d);
+        const float id = 1.0f / d;
+
+        for (int j = 0; j < 32; j++) {
+            uint8_t b = 0;
+            for (int n = 0; n < 4; n++) {
+                const float v = x[j + n * 32];
+                // NaN/Inf guard
+                const float vg = (v == v && v != INFINITY && v != -INFINITY) ? v : 0.0f;
+                int q = (int)roundf(vg * id + 1.5f);
+                if (q < 0) q = 0;
+                if (q > 3) q = 3;
+                b |= (uint8_t)(q << (n * 2));
+            }
+            y[i].qs[j] = b;
+        }
+        x += QK_TQ2_KV;
+    }
+}
+
+void dequantize_row_tq2_kv(const block_tq2_kv * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ2_KV == 0);
+    const int64_t nb = k / QK_TQ2_KV;
+
+    for (int64_t i = 0; i < nb; i++) {
+        const float d = GGML_FP16_TO_FP32(x[i].d);
+
+        for (int n = 0; n < 4; n++) {
+            for (int j = 0; j < 32; j++) {
+                const int q = (x[i].qs[j] >> (n * 2)) & 3;
+                y[n * 32 + j] = (q - 1.5f) * d;
+            }
+        }
+        y += QK_TQ2_KV;
+    }
+}
+
+size_t quantize_tq2_kv(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst, int64_t nrows, int64_t n_per_row, const float * imatrix) {
+    (void)imatrix;
+    const size_t row_size = ggml_row_size(GGML_TYPE_TQ2_KV, n_per_row);
+    quantize_row_tq2_kv_ref(src, dst, (int64_t)nrows * n_per_row);
+    return nrows * row_size;
+}
