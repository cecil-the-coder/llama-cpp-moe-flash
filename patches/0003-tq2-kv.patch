+// ====================== TQ2_KV (2-bit KV cache quantization, QK=128)
+
+void quantize_row_tq2_kv_ref(const float * GGML_RESTRICT x, block_tq2_kv * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ2_KV == 0);
+    const int64_t nb = k / QK_TQ2_KV;
+
+    for (int64_t i = 0; i < nb; i++) {
+        float amax = 0.0f;
+
+        for (int j = 0; j < QK_TQ2_KV; j++) {
+            const float v = x[j];
+            // NaN/Inf guard
+            if (v == v && fabsf(v) != INFINITY) {
+                amax = MAX(amax, fabsf(v));
+            }
+        }
+
+        const float d = amax;
+        const float id = d ? 1.0f/d : 0.0f;
+
+        y[i].d = GGML_FP32_TO_FP16(d);
+
+        for (int j = 0; j < QK_TQ2_KV/4; j++) {
+            uint8_t q = 0;
+            for (int n = 0; n < 4; ++n) {
+                float v = x[j*4 + n];
+                // NaN/Inf -> 0 (maps to trit 1, i.e. zero)
+                if (v != v || fabsf(v) == INFINITY) { v = 0.0f; }
+                int xi = lroundf(v * id) + 1;
+                if (xi < 0) xi = 0;
+                if (xi > 2) xi = 2;
+                q |= (xi & 3) << (2*n);
+            }
+            y[i].qs[j] = q;
+        }
+        x += QK_TQ2_KV;
+    }
+}
+
+size_t quantize_tq2_kv(const float * GGML_RESTRICT src, void * GGML_RESTRICT dst, int64_t nrow, int64_t n_per_row, const float * quant_weights) {
+    (void)quant_weights;
+    const size_t row_size = ggml_row_size(GGML_TYPE_TQ2_KV, n_per_row);
+    quantize_row_tq2_kv_ref(src, dst, (int64_t)nrow*n_per_row);
+    return nrow * row_size;
+}
+
+void dequantize_row_tq2_kv(const block_tq2_kv * GGML_RESTRICT x, float * GGML_RESTRICT y, int64_t k) {
+    assert(k % QK_TQ2_KV == 0);
+    const int64_t nb = k / QK_TQ2_KV;
+
+    for (int64_t i = 0; i < nb; ++i) {
+        const float d = GGML_FP16_TO_FP32(x[i].d);
+
+        for (int j = 0; j < QK_TQ2_KV/4; j++) {
+            for (int n = 0; n < 4; ++n) {
+                int8_t q = (x[i].qs[j] >> (n*2)) & 3;
+                *y++ = (float)(q - 1) * d;
+            }
+        }
+    }
+}
