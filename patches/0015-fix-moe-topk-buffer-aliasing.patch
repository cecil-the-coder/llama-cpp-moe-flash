From 0c30eaaf6d7d234cb34e3b5dfc016b2cfba48df0 Mon Sep 17 00:00:00 2001
From: Shadow <shadow@code-puppy.dev>
Date: Tue, 31 Mar 2026 11:46:49 +0000
Subject: [PATCH] Conditionally mark MoE topk indices as input+output for slot
 buffer mode only

Only apply ggml_set_input+ggml_set_output when LLAMA_MOE_SLOT_BUFFER=1
is set (>GTT models using slot buffer). For normal models these flags
change the gallocr allocation pattern and corrupt output.

---
 src/llama-graph.cpp | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/src/llama-graph.cpp b/src/llama-graph.cpp
index 6416b99..cfa48b7 100644
--- a/src/llama-graph.cpp
+++ b/src/llama-graph.cpp
@@ -1317,6 +1317,13 @@ ggml_tensor * llm_graph_context::build_moe_ffn(
     ggml_tensor * selected_experts = ggml_argsort_top_k(ctx0, selection_probs, n_expert_used); // [n_expert_used, n_tokens]
     cb(selected_experts->src[0], "ffn_moe_argsort", il);
     cb(selected_experts, "ffn_moe_topk", il);
+    // I11: In slot buffer mode, mark topk indices as input+output to prevent
+    // buffer aliasing and premature freeing. Only for >GTT models — applying
+    // these flags unconditionally changes gallocr allocation and corrupts output.
+    if (getenv("LLAMA_MOE_SLOT_BUFFER") && strcmp(getenv("LLAMA_MOE_SLOT_BUFFER"), "1") == 0) {
+        ggml_set_input(selected_experts);
+        ggml_set_output(selected_experts);
+    }

     if (arch == LLM_ARCH_GROVEMOE && n_expert != hparams.n_expert) {
         // TODO: Use scalar div instead when/if implemented
