diff --git a/include/llama-moe-flash.h b/include/llama-moe-flash.h
new file mode 100644
index 0000000..0bfd8bb
--- /dev/null
+++ b/include/llama-moe-flash.h
@@ -0,0 +1,54 @@
+#pragma once
+
+#include "llama.h"
+#include "ggml-backend.h"
+
+#include <cstdint>
+#include <stdbool.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+// ── MoE Flash: expert weight prefetching ────────────────────────────────
+//
+// Modes (set via LLAMA_FLASH_MOE_MODE env var):
+//
+//   "callback"  — Original eval callback approach. Intercepts routing
+//                 decisions per-layer but serializes GPU execution (~7x slower).
+//                 Only useful for debugging/routing analysis.
+//
+//   "prefetch"  — (Default) Background prefetch thread that cycles through
+//                 MoE layers calling madvise(MADV_WILLNEED) on the mmap'd
+//                 expert tensor regions. Zero inference overhead.
+//
+//   "fadvise"   — Before each graph compute, issue posix_fadvise(WILLNEED)
+//                 for all expert regions in upcoming layers. Zero inference
+//                 overhead but less targeted than routing-aware prefetch.
+
+struct llama_moe_flash_context;
+
+// Initialize the flash MoE context. Returns nullptr if disabled or on error.
+struct llama_moe_flash_context * llama_moe_flash_init(const char * experts_dir);
+
+// Free the flash MoE context.
+void llama_moe_flash_free(struct llama_moe_flash_context * ctx);
+
+// Returns true if the eval callback should be installed.
+// Only true for "callback" mode; other modes have zero overhead.
+bool llama_moe_flash_needs_callback(struct llama_moe_flash_context * ctx);
+
+// Get the eval callback function (only for "callback" mode).
+ggml_backend_sched_eval_callback llama_moe_flash_get_callback(void);
+
+// Get the context pointer to pass as cb_eval_user_data.
+void * llama_moe_flash_get_user_data(struct llama_moe_flash_context * ctx);
+
+// Notify the prefetch system that a decode is about to start.
+// Call this before graph_compute. For "prefetch" and "fadvise" modes,
+// this triggers the pre-graph advisory. For "callback" mode, this is a no-op.
+void llama_moe_flash_pre_graph(struct llama_moe_flash_context * ctx);
+
+#ifdef __cplusplus
+}
+#endif
