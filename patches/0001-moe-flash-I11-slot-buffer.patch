+// ── GGUF source mapping (for page cache warming) ──────────────────────
+
+// Maps (layer, expert) to regions in the original GGUF file.
+// Reading these regions via io_uring warms the page cache so that
+// the mmap'd tensor access doesn't cause major page faults.
+struct gguf_expert_part {
+    size_t offset;   // absolute file offset in the GGUF
+    size_t size;     // bytes to read
+};
+
+struct gguf_expert_region {
+    std::vector<gguf_expert_part> parts; // gate, up, down tensor slices
+    size_t total_size;                    // sum of all parts
+};
+
+struct gguf_layer_source {
+    int layer_idx;
+    int fd;        // file descriptor for the GGUF shard containing this layer
+    int n_experts;
+    std::vector<gguf_expert_region> experts; // indexed by expert_id
+};
+
+struct gguf_source {
+    int         fd;        // open file descriptor for first shard
+    std::string path;
+    std::vector<gguf_layer_source> layers;
+    std::unordered_map<int, int> layer_idx_to_pos;
+    std::vector<int> extra_fds; // fds for additional shards
+};
+
+// ── Manifest types ─────────────────────────────────────────────────────
+
+struct expert_part {
+    std::string name;     // "gate", "up", "down", or "gate_up"
+    size_t      offset;   // offset within the expert file
+    size_t      size;     // bytes
+};
+
+struct expert_entry {
+    int         id;
+    std::string file;
+    size_t      raw_size;
+    size_t      padded_size;
+    std::vector<expert_part> parts;
+    int         fd;       // open file descriptor (for prefetch)
+};
+
+struct layer_entry {
+    int layer_idx;
+    int n_experts;
+    std::vector<expert_entry> experts;
+};
