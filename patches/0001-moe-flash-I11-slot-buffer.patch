+// ── io_uring staging pool ──────────────────────────────────────────────
+
+#if defined(GGML_USE_IOURING)
+
+#define MOE_FLASH_MAX_EXPERTS_PER_TOKEN 16  // max K (top-k) per token
+#define MOE_FLASH_STAGING_ALIGN (2 * 1024 * 1024)  // 2 MB alignment for O_DIRECT
+
+struct iouring_staging_slot {
+    void *  data;           // 2MB-aligned host pointer
+    size_t  capacity;       // allocated size
+    int     expert_id;      // which expert is loaded here (-1 = empty)
+    int     layer;          // which layer
+};
+
+struct iouring_prefetcher {
+    struct io_uring ring;
+    bool            ring_initialized;
+
+    // Staging slots — one set for active reads
+    std::vector<iouring_staging_slot> slots;
+    int n_slots;
+
+    // Pending read tracking
+    int     n_pending;
+    int     pending_layer;
+    int32_t pending_ids[MOE_FLASH_MAX_EXPERTS_PER_TOKEN];
+
+    // Timing stats
+    int64_t total_submit_ns;
+    int64_t total_wait_ns;
+    int64_t n_submits;
+    int64_t n_waits;
+    int64_t total_bytes_read;
+};
+
+static bool iouring_prefetcher_init(iouring_prefetcher * pf, int n_slots, size_t max_expert_size) {
+    memset(pf, 0, sizeof(*pf));
+    pf->n_slots = n_slots;
+    pf->ring_initialized = false;
+
+    // Initialize io_uring
+    // Try SQPOLL first (lower latency), then normal mode, then smaller queue
+    int ret = -1;
+    struct io_uring_params params = {};
+
+    // Attempt 1: SQPOLL (needs CAP_SYS_NICE or root)
+    params.flags = IORING_SETUP_SQPOLL;
+    params.sq_thread_idle = 2000;
+    ret = io_uring_queue_init_params(32, &pf->ring, &params);
+
+    if (ret < 0) {
+        // Attempt 2: normal mode, moderate queue
+        fprintf(stderr, "moe-flash: SQPOLL init failed (%d), trying normal mode\n", -ret);
+        ret = io_uring_queue_init(32, &pf->ring, 0);
+    }
+
+    if (ret < 0) {
+        // Attempt 3: minimal queue (may work with low memlock limits)
+        fprintf(stderr, "moe-flash: normal init failed (%d), trying minimal queue\n", -ret);
+        ret = io_uring_queue_init(8, &pf->ring, 0);
+    }
+
+    if (ret < 0) {
+        fprintf(stderr, "moe-flash: io_uring init failed: %d (check ulimit -l, currently %d KB)\n",
+                -ret, (int)(sysconf(_SC_MEMLOCK) / 1024));
+        fprintf(stderr, "moe-flash: hint: increase memlock with 'ulimit -l unlimited' or set "
+                "LimitMEMLOCK=infinity in container security context\n");
+        return false;
+    }
+    pf->ring_initialized = true;
+    fprintf(stderr, "moe-flash: io_uring ring created (sq_entries=%u)\n", params.sq_entries);
+
+    // Allocate staging slots with aligned memory
+    size_t alloc_size = (max_expert_size + MOE_FLASH_STAGING_ALIGN - 1) & ~(size_t)(MOE_FLASH_STAGING_ALIGN - 1);
+    pf->slots.resize(n_slots);
+
+    for (int i = 0; i < n_slots; i++) {
+        void * ptr = nullptr;
+        if (posix_memalign(&ptr, MOE_FLASH_STAGING_ALIGN, alloc_size) != 0) {
+            fprintf(stderr, "moe-flash: posix_memalign failed for slot %d\n", i);
+            return false;
+        }
+        pf->slots[i].data = ptr;
+        pf->slots[i].capacity = alloc_size;
+        pf->slots[i].expert_id = -1;
+        pf->slots[i].layer = -1;
+    }
+
+    // Register buffers for zero-copy fixed reads
+    std::vector<struct iovec> iovs(n_slots);
+    for (int i = 0; i < n_slots; i++) {
+        iovs[i].iov_base = pf->slots[i].data;
+        iovs[i].iov_len = alloc_size;
+    }
+    ret = io_uring_register_buffers(&pf->ring, iovs.data(), n_slots);
+    if (ret < 0) {
+        fprintf(stderr, "moe-flash: buffer registration failed (%d), using non-fixed reads\n", -ret);
+        // Non-fatal: we'll use regular reads instead of fixed
+    }
+
+    fprintf(stderr, "moe-flash: io_uring initialized: %d slots × %zu bytes (%zu MB total)\n",
+            n_slots, alloc_size, (size_t)n_slots * alloc_size / (1024 * 1024));
+
+    return true;
+}
+
+static void iouring_prefetcher_destroy(iouring_prefetcher * pf) {
+    if (pf->ring_initialized) {
+        io_uring_queue_exit(&pf->ring);
+        pf->ring_initialized = false;
+    }
+    for (auto & slot : pf->slots) {
+        if (slot.data) {
+            free(slot.data);
+            slot.data = nullptr;
+        }
+    }
+}
