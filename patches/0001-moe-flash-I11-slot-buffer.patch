+// Submit async reads for selected experts in the given layer
+// Submit reads from split expert files into staging buffers
+static void iouring_prefetcher_submit(
+        iouring_prefetcher * pf,
+        const std::vector<layer_entry> & layers,
+        const std::unordered_map<int, int> & layer_idx_to_pos,
+        int layer_idx,
+        const int32_t * expert_ids,
+        int k) {
+    auto it = layer_idx_to_pos.find(layer_idx);
+    if (it == layer_idx_to_pos.end()) return;
+
+    const layer_entry & le = layers[it->second];
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    int submitted = 0;
+    for (int i = 0; i < k && i < pf->n_slots; i++) {
+        int eid = expert_ids[i];
+        if (eid < 0 || eid >= le.n_experts) continue;
+
+        const expert_entry & ee = le.experts[eid];
+        if (ee.fd < 0) continue;
+
+        iouring_staging_slot & slot = pf->slots[i];
+
+        struct io_uring_sqe * sqe = io_uring_get_sqe(&pf->ring);
+        if (!sqe) {
+            fprintf(stderr, "moe-flash: no SQE available\n");
+            break;
+        }
+
+        io_uring_prep_read(sqe, ee.fd, slot.data, ee.raw_size, 0);
+        io_uring_sqe_set_data(sqe, (void *)(uintptr_t)i);
+
+        slot.expert_id = eid;
+        slot.layer = layer_idx;
+        pf->pending_ids[submitted] = eid;
+        submitted++;
+    }
+
+    if (submitted > 0) {
+        io_uring_submit(&pf->ring);
+    }
+
+    pf->n_pending = submitted;
+    pf->pending_layer = layer_idx;
+    pf->n_submits++;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_submit_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Submit reads from original GGUF file to warm page cache.
+// The data goes into staging buffers (which we discard), but the side effect
+// is that the kernel populates the page cache for these GGUF regions.
+// When the mmap'd tensor is subsequently accessed by the Vulkan shader,
+// the data is already in page cache → no major faults.
+static void iouring_prefetcher_submit_gguf(
+        iouring_prefetcher * pf,
+        const gguf_source & src,
+        int layer_idx,
+        const int32_t * expert_ids,
+        int k) {
+    auto it = src.layer_idx_to_pos.find(layer_idx);
+    if (it == src.layer_idx_to_pos.end()) return;
+
+    const gguf_layer_source & ls = src.layers[it->second];
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    // Submit one io_uring read per tensor part per expert.
+    // Each part (gate, up, down) is a separate contiguous region in the GGUF.
+    // The reads go into staging buffers (which are discarded), but the side
+    // effect is that the kernel populates the page cache for these regions.
+    int submitted = 0;
+    int slot_idx = 0;
+    for (int i = 0; i < k; i++) {
+        int eid = expert_ids[i];
+        if (eid < 0 || eid >= ls.n_experts) continue;
+
+        const gguf_expert_region & region = ls.experts[eid];
+
+        for (const auto & part : region.parts) {
+            if (slot_idx >= pf->n_slots) break;
+
+            iouring_staging_slot & slot = pf->slots[slot_idx % pf->n_slots];
+            size_t read_size = std::min(part.size, slot.capacity);
+
+            struct io_uring_sqe * sqe = io_uring_get_sqe(&pf->ring);
+            if (!sqe) goto done_submit;
+
+            io_uring_prep_read(sqe, src.fd, slot.data, read_size, part.offset);
+            io_uring_sqe_set_data(sqe, (void *)(uintptr_t)submitted);
+            submitted++;
+        }
+
+        pf->pending_ids[slot_idx] = eid;
+        slot_idx++;
+    }
+
+done_submit:
+    if (submitted > 0) {
+        io_uring_submit(&pf->ring);
+    }
+
+    pf->n_pending = submitted;
+    pf->pending_layer = layer_idx;
+    pf->n_submits++;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_submit_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Wait for all pending reads to complete
+static void iouring_prefetcher_wait(iouring_prefetcher * pf) {
+    if (pf->n_pending == 0) return;
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    struct io_uring_cqe * cqe;
+    for (int i = 0; i < pf->n_pending; i++) {
+        int ret = io_uring_wait_cqe(&pf->ring, &cqe);
+        if (ret < 0) {
+            fprintf(stderr, "moe-flash: io_uring wait failed: %d\n", -ret);
+            break;
+        }
+        if (cqe->res < 0) {
+            fprintf(stderr, "moe-flash: read failed for slot %llu: %d\n",
+                    (unsigned long long)(unsigned long long)(uintptr_t)io_uring_cqe_get_data(cqe), cqe->res);
+        } else {
+            pf->total_bytes_read += cqe->res;
+        }
+        io_uring_cqe_seen(&pf->ring, cqe);
+    }
+
+    pf->n_waits++;
+    pf->n_pending = 0;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_wait_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
