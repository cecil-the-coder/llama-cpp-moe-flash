+    // Background prefetch thread (MOE_FLASH_MODE_PREFETCH)
+    std::thread             prefetch_thread;
+    std::atomic<bool>       prefetch_running{false};
+    std::atomic<int>        prefetch_signal{0};  // incremented on each pre_graph call
+    int64_t                 prefetch_madvise_calls;
