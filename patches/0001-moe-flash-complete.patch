From 175feb3698e0092869eed00c8955c4da8e37a8fa Mon Sep 17 00:00:00 2001
From: moe-flash <moe-flash@localhost>
Date: Tue, 24 Mar 2026 07:29:05 +0000
Subject: [PATCH 10/12] ggml-vulkan: enable buffer_from_host_ptr when
 external_memory_host is available
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The Vulkan backend hardcodes buffer_from_host_ptr=false despite having
a working VK_EXT_external_memory_host implementation. This forces the
model loader to allocate a SEPARATE Vulkan buffer and memcpy all weight
data into it, doubling memory usage.

On UMA systems (e.g., AMD Strix Halo), this causes OOM for large models:
228 GB model → 228 GB mmap + 228 GB Vulkan copy = 456 GB on 125 GB RAM.

With this fix, the model loader uses buffer_from_host_ptr to wrap the
mmap'd GGUF data directly as a Vulkan buffer — zero copy, zero additional
memory. The VK_EXT_external_memory_host import creates a Vulkan memory
object backed by the existing mmap pages.
---
 ggml/src/ggml-vulkan/ggml-vulkan.cpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/ggml/src/ggml-vulkan/ggml-vulkan.cpp b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
index 61d112c50..8714c50d3 100644
--- a/ggml/src/ggml-vulkan/ggml-vulkan.cpp
+++ b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
@@ -14942,10 +14942,11 @@ static void ggml_backend_vk_device_get_props(ggml_backend_dev_t dev, struct ggml
     props->type        = ggml_backend_vk_device_get_type(dev);
     props->device_id   = ctx->pci_bus_id.empty() ? nullptr : ctx->pci_bus_id.c_str();
     ggml_backend_vk_device_get_memory(dev, &props->memory_free, &props->memory_total);
+    auto device = ggml_vk_get_device(ctx->device);
     props->caps = {
         /* .async                 = */ true,
         /* .host_buffer           = */ true,
-        /* .buffer_from_host_ptr  = */ false,
+        /* .buffer_from_host_ptr  = */ device->external_memory_host,
         /* .events                = */ true,
     };
 }
-- 
