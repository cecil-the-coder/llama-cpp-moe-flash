diff --git a/src/llama-moe-flash.cpp b/src/llama-moe-flash.cpp
new file mode 100644
index 000000000..578dd1a08
--- /dev/null
+++ b/src/llama-moe-flash.cpp
@@ -0,0 +1,374 @@
+#include "llama-moe-flash.h"
+#include "ggml.h"
+#include "ggml-backend.h"
+
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <string>
+#include <vector>
+#include <unordered_map>
+
+#if defined(__linux__)
+#include <fcntl.h>
+#include <unistd.h>
+#endif
+
+// ── Manifest types ─────────────────────────────────────────────────────
+
+struct expert_part {
+    std::string name;     // "gate", "up", "down", or "gate_up"
+    size_t      offset;   // offset within the expert file
+    size_t      size;     // bytes
+};
+
+struct expert_entry {
+    int         id;
+    std::string file;
+    size_t      raw_size;
+    size_t      padded_size;
+    std::vector<expert_part> parts;
+    int         fd;       // open file descriptor (for prefetch)
+};
+
+struct layer_entry {
+    int layer_idx;
+    int n_experts;
+    std::vector<expert_entry> experts;
+};
+
+// ── Flash MoE context ──────────────────────────────────────────────────
+
+struct llama_moe_flash_context {
+    bool        enabled;
+    bool        log_routing;       // log routing decisions to stderr
+    bool        prefetch_fadvise;  // use posix_fadvise(WILLNEED)
+
+    std::string experts_dir;
+    std::vector<layer_entry> layers;
+    std::unordered_map<int, int> layer_idx_to_pos; // layer_idx → position in layers[]
+
+    // Scratch buffer for reading tensor data from GPU
+    std::vector<int32_t> topk_buf;
+
+    // Stats
+    int64_t n_callbacks;
+    int64_t n_prefetch_calls;
+};
+
+// ── Helpers ────────────────────────────────────────────────────────────
+
+// Parse layer index from tensor name like "ffn_moe_topk-5" → 5
+static int parse_layer_index(const char * name) {
+    // Find the last '-' and parse the number after it
+    const char * dash = strrchr(name, '-');
+    if (dash && dash[1] >= '0' && dash[1] <= '9') {
+        return atoi(dash + 1);
+    }
+    return -1;
+}
+
+// ── Manifest loader ────────────────────────────────────────────────────
+
+// Minimal JSON parser for manifest.json (avoids external dependency).
+// The manifest has a known, simple structure so we parse it with string ops.
+static bool load_manifest(llama_moe_flash_context * ctx) {
+    std::string manifest_path = ctx->experts_dir + "/manifest.json";
+    FILE * f = fopen(manifest_path.c_str(), "r");
+    if (!f) {
+        fprintf(stderr, "moe-flash: cannot open manifest: %s\n", manifest_path.c_str());
+        return false;
+    }
+
+    // Read entire file
+    fseek(f, 0, SEEK_END);
+    long size = ftell(f);
+    fseek(f, 0, SEEK_SET);
+    std::string json(size, '\0');
+    size_t nread = fread(&json[0], 1, size, f);
+    fclose(f);
+    if ((long)nread != size) {
+        fprintf(stderr, "moe-flash: short read on manifest\n");
+        return false;
+    }
+
+    // Parse layer entries using simple string scanning.
+    // We look for "layer": N patterns and "experts": [...] arrays.
+    // This is fragile but sufficient for our known manifest format.
+
+    size_t pos = 0;
+    auto find_key = [&](const std::string & key) -> size_t {
+        size_t p = json.find("\"" + key + "\"", pos);
+        if (p == std::string::npos) return std::string::npos;
+        p = json.find(':', p + key.size() + 2);
+        return p != std::string::npos ? p + 1 : std::string::npos;
+    };
+
+    auto read_int = [&](size_t p) -> int {
+        while (p < json.size() && (json[p] == ' ' || json[p] == '\t' || json[p] == '\n' || json[p] == '\r')) p++;
+        return atoi(&json[p]);
+    };
+
+    auto read_string = [&](size_t p) -> std::string {
+        size_t q1 = json.find('"', p);
+        if (q1 == std::string::npos) return "";
+        size_t q2 = json.find('"', q1 + 1);
+        if (q2 == std::string::npos) return "";
+        return json.substr(q1 + 1, q2 - q1 - 1);
+    };
+
+    // Find top-level "layers" array
+    size_t layers_pos = json.find("\"layers\"");
+    if (layers_pos == std::string::npos) {
+        fprintf(stderr, "moe-flash: no 'layers' key in manifest\n");
+        return false;
+    }
+
+    // Scan for each layer object
+    size_t scan = layers_pos;
+    while (true) {
+        // Find next "layer": N
+        size_t layer_key = json.find("\"layer\"", scan);
+        if (layer_key == std::string::npos) break;
+
+        size_t colon = json.find(':', layer_key + 7);
+        if (colon == std::string::npos) break;
+        int layer_idx = read_int(colon + 1);
+
+        layer_entry le;
+        le.layer_idx = layer_idx;
+
+        // Find "experts" array for this layer
+        size_t experts_key = json.find("\"experts\"", colon);
+        if (experts_key == std::string::npos) break;
+
+        // Find next layer boundary or end of layers array
+        size_t next_layer = json.find("\"layer\"", experts_key + 10);
+        size_t search_end = (next_layer != std::string::npos) ? next_layer : json.size();
+
+        // Scan expert entries within this range
+        size_t exp_scan = experts_key;
+        while (exp_scan < search_end) {
+            size_t id_key = json.find("\"id\"", exp_scan);
+            if (id_key == std::string::npos || id_key >= search_end) break;
+
+            expert_entry ee;
+            size_t id_colon = json.find(':', id_key + 4);
+            ee.id = read_int(id_colon + 1);
+
+            pos = id_colon;
+            size_t file_pos = find_key("file");
+            if (file_pos != std::string::npos) {
+                ee.file = read_string(file_pos);
+            }
+
+            // Read raw_size and padded_size
+            pos = file_pos;
+            size_t raw_pos = find_key("raw_size");
+            if (raw_pos != std::string::npos) {
+                ee.raw_size = read_int(raw_pos);
+            }
+
+            pos = raw_pos;
+            size_t pad_pos = find_key("padded_size");
+            if (pad_pos != std::string::npos) {
+                ee.padded_size = read_int(pad_pos);
+            }
+
+            // Open file descriptor for prefetch
+            ee.fd = -1;
+            if (!ee.file.empty() && ctx->prefetch_fadvise) {
+                std::string path = ctx->experts_dir + "/" + ee.file;
+                ee.fd = open(path.c_str(), O_RDONLY);
+                if (ee.fd < 0) {
+                    fprintf(stderr, "moe-flash: warning: cannot open %s\n", path.c_str());
+                }
+            }
+
+            le.experts.push_back(std::move(ee));
+            exp_scan = (pad_pos != std::string::npos) ? pad_pos + 10 : exp_scan + 10;
+        }
+
+        le.n_experts = (int)le.experts.size();
+        ctx->layer_idx_to_pos[layer_idx] = (int)ctx->layers.size();
+        ctx->layers.push_back(std::move(le));
+
+        scan = (next_layer != std::string::npos) ? next_layer : json.size();
+    }
+
+    fprintf(stderr, "moe-flash: loaded manifest: %zu layers, %d experts/layer\n",
+            ctx->layers.size(),
+            ctx->layers.empty() ? 0 : ctx->layers[0].n_experts);
+
+    return !ctx->layers.empty();
+}
+
+// ── Eval callback ──────────────────────────────────────────────────────
+
+static bool moe_flash_eval_cb(struct ggml_tensor * t, bool ask, void * user_data) {
+    auto * ctx = (llama_moe_flash_context *)user_data;
+
+    if (ask) {
+        // We only need data from ffn_moe_topk tensors
+        if (strstr(t->name, "ffn_moe_topk") != nullptr) {
+            return true;
+        }
+        return false;
+    }
+
+    // Observe phase: tensor data is ready
+    if (strstr(t->name, "ffn_moe_topk") == nullptr) {
+        return true;
+    }
+
+    ctx->n_callbacks++;
+
+    int layer_idx = parse_layer_index(t->name);
+    if (layer_idx < 0) {
+        return true;
+    }
+
+    // Read the selected expert IDs from the tensor.
+    // Shape: [n_expert_used, n_tokens] — we read all of it.
+    // On UMA (Strix Halo), ggml_backend_tensor_get is just a memcpy.
+    const int64_t n_expert_used = t->ne[0];
+    const int64_t n_tokens      = t->ne[1];
+    const size_t  n_ids         = n_expert_used * n_tokens;
+
+    ctx->topk_buf.resize(n_ids);
+
+    const bool is_host = ggml_backend_buffer_is_host(t->buffer);
+    if (is_host) {
+        memcpy(ctx->topk_buf.data(), t->data, n_ids * sizeof(int32_t));
+    } else {
+        ggml_backend_tensor_get(t, ctx->topk_buf.data(), 0, n_ids * sizeof(int32_t));
+    }
+
+    // Log routing decisions
+    if (ctx->log_routing) {
+        fprintf(stderr, "moe-flash: layer %3d topk=[", layer_idx);
+        // Only log first token's experts (avoid flooding for batch)
+        for (int64_t i = 0; i < n_expert_used && i < 16; i++) {
+            if (i > 0) fprintf(stderr, ",");
+            fprintf(stderr, "%d", ctx->topk_buf[i]);
+        }
+        if (n_tokens > 1) {
+            fprintf(stderr, "] (%lld tokens)", (long long)n_tokens);
+        } else {
+            fprintf(stderr, "]");
+        }
+        fprintf(stderr, "\n");
+    }
+
+    // Prefetch: issue posix_fadvise for the NEXT layer's experts
+    // (Current layer's experts are already needed; prefetch one layer ahead)
+    if (ctx->prefetch_fadvise && !ctx->layers.empty()) {
+        int next_layer = layer_idx + 1;
+        auto it = ctx->layer_idx_to_pos.find(next_layer);
+        if (it != ctx->layer_idx_to_pos.end()) {
+            const layer_entry & le = ctx->layers[it->second];
+
+            // For each token, prefetch its selected experts for next layer
+            // Deduplicate across tokens to avoid redundant fadvise calls
+            std::vector<bool> needed(le.n_experts, false);
+            for (int64_t tok = 0; tok < n_tokens; tok++) {
+                for (int64_t k = 0; k < n_expert_used; k++) {
+                    int eid = ctx->topk_buf[tok * n_expert_used + k];
+                    if (eid >= 0 && eid < le.n_experts) {
+                        needed[eid] = true;
+                    }
+                }
+            }
+
+#if defined(__linux__)
+            for (int e = 0; e < le.n_experts; e++) {
+                if (!needed[e]) continue;
+                const expert_entry & ee = le.experts[e];
+                if (ee.fd >= 0) {
+                    posix_fadvise(ee.fd, 0, ee.raw_size, POSIX_FADV_WILLNEED);
+                    ctx->n_prefetch_calls++;
+                }
+            }
+#endif
+        }
+    }
+
+    return true;
+}
+
+// ── Public API ─────────────────────────────────────────────────────────
+
+struct llama_moe_flash_context * llama_moe_flash_init(const char * experts_dir) {
+    const char * enabled_env = getenv("LLAMA_FLASH_MOE_ENABLED");
+    if (!enabled_env || strcmp(enabled_env, "1") != 0) {
+        return nullptr;
+    }
+
+    auto * ctx = new llama_moe_flash_context();
+    ctx->enabled = true;
+    ctx->n_callbacks = 0;
+    ctx->n_prefetch_calls = 0;
+
+    // Configuration from env vars
+    const char * log_env = getenv("LLAMA_FLASH_MOE_LOG_ROUTING");
+    ctx->log_routing = (log_env && strcmp(log_env, "1") == 0);
+
+    const char * fadvise_env = getenv("LLAMA_FLASH_MOE_FADVISE");
+    ctx->prefetch_fadvise = (fadvise_env && strcmp(fadvise_env, "1") == 0);
+
+    // Experts directory
+    if (experts_dir) {
+        ctx->experts_dir = experts_dir;
+    } else {
+        const char * dir_env = getenv("LLAMA_FLASH_MOE_EXPERTS_DIR");
+        if (dir_env) {
+            ctx->experts_dir = dir_env;
+        }
+    }
+
+    // Load manifest if experts directory is set
+    if (!ctx->experts_dir.empty()) {
+        if (!load_manifest(ctx)) {
+            fprintf(stderr, "moe-flash: failed to load manifest, prefetch disabled\n");
+            ctx->prefetch_fadvise = false;
+        }
+    }
+
+    // Default: enable routing log if no other mode is set
+    if (!ctx->prefetch_fadvise) {
+        ctx->log_routing = true;
+    }
+
+    fprintf(stderr, "moe-flash: initialized (log=%d, fadvise=%d, experts_dir=%s)\n",
+            ctx->log_routing, ctx->prefetch_fadvise,
+            ctx->experts_dir.empty() ? "(none)" : ctx->experts_dir.c_str());
+
+    return ctx;
+}
+
+void llama_moe_flash_free(struct llama_moe_flash_context * ctx) {
+    if (!ctx) return;
+
+    fprintf(stderr, "moe-flash: stats: %lld callbacks, %lld prefetch calls\n",
+            (long long)ctx->n_callbacks, (long long)ctx->n_prefetch_calls);
+
+    // Close file descriptors
+    for (auto & layer : ctx->layers) {
+        for (auto & expert : layer.experts) {
+            if (expert.fd >= 0) {
+                close(expert.fd);
+                expert.fd = -1;
+            }
+        }
+    }
+
+    delete ctx;
+}
+
+ggml_backend_sched_eval_callback llama_moe_flash_get_callback(void) {
+    return moe_flash_eval_cb;
+}
+
+void * llama_moe_flash_get_user_data(struct llama_moe_flash_context * ctx) {
+    return (void *)ctx;
+}
