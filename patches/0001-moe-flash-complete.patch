+// ── GGUF header scanner (for page cache warming) ─────────────────────
+
+// Minimal GGUF header parsing to find expert tensor offsets.
+// This allows io_uring to read from the original GGUF at the exact offsets
+// where expert data lives, warming the page cache for the mmap'd tensor.
+
+static void gguf_skip_value(FILE * f, int vtype) {
+    static const int sizes[] = {1,1,2,2,4,4,4,1,8,0,8,8,8,4};
+    if (vtype == 8) { // string
+        uint64_t len; if (fread(&len, 8, 1, f) != 1) return; fseek(f, (long)len, SEEK_CUR);
+    } else if (vtype == 9) { // array
+        int32_t atype; if (fread(&atype, 4, 1, f) != 1) return;
+        uint64_t alen; if (fread(&alen, 8, 1, f) != 1) return;
+        for (uint64_t i = 0; i < alen; i++) gguf_skip_value(f, atype);
+    } else if (vtype >= 0 && vtype <= 13) {
+        fseek(f, sizes[vtype], SEEK_CUR);
+    }
+}
+
+static std::string gguf_read_string(FILE * f) {
+    uint64_t len = 0;
+    if (fread(&len, 8, 1, f) != 1) return "";
+    std::string s(len, '\0');
+    if (fread(&s[0], 1, len, f) != len) return "";
+    return s;
+}
+
+// GGML type info: (block_size_elements, block_size_bytes)
+static size_t gguf_type_bytes(int ttype, size_t n_elements) {
+    static const int block_elems[] = {1,1,32,32,0,0,32,32,32,32,256,256,256,256,256,256,256,256,256,256,32,256,256,256,256,1,32,32,32,0,256,256,32};
+    static const int block_bytes[] = {4,2,18,20,0,0,20,24,34,36,84,110,144,176,210,292,66,74,98,54,18,110,66,70,56,2,18,18,18,0,54,66,18};
+    if (ttype < 0 || ttype > 32 || block_elems[ttype] == 0) return 0;
+    return (n_elements / block_elems[ttype]) * block_bytes[ttype];
+}
+
+static bool load_gguf_source(gguf_source * src, const char * gguf_path) {
+    FILE * f = fopen(gguf_path, "rb");
+    if (!f) {
+        fprintf(stderr, "moe-flash: cannot open GGUF: %s\n", gguf_path);
+        return false;
+    }
+
+    // Read header
+    char magic[4];
+    if (fread(magic, 4, 1, f) != 1 || memcmp(magic, "GGUF", 4) != 0) {
+        fprintf(stderr, "moe-flash: not a GGUF file: %s\n", gguf_path);
+        fclose(f); return false;
+    }
+    uint32_t version = 0; (void)fread(&version, 4, 1, f);
+    uint64_t n_tensors = 0; (void)fread(&n_tensors, 8, 1, f);
+    uint64_t n_kv = 0; (void)fread(&n_kv, 8, 1, f);
+
+    // Skip KV pairs
+    uint32_t alignment = 32;
+    for (uint64_t i = 0; i < n_kv; i++) {
+        std::string key = gguf_read_string(f);
+        uint32_t vtype = 0; (void)fread(&vtype, 4, 1, f);
+        if (key == "general.alignment" && vtype == 4) {
+            (void)fread(&alignment, 4, 1, f);
+        } else {
+            gguf_skip_value(f, vtype);
+        }
+    }
+
+    // Read tensor metadata
+    struct tensor_meta {
+        std::string name;
+        std::vector<uint64_t> dims;
+        int ttype;
+        uint64_t offset;
+        size_t n_bytes;
+    };
+    std::vector<tensor_meta> tensors;
+
+    for (uint64_t i = 0; i < n_tensors; i++) {
+        tensor_meta tm;
+        tm.name = gguf_read_string(f);
+        uint32_t n_dims = 0; (void)fread(&n_dims, 4, 1, f);
+        tm.dims.resize(n_dims);
+        for (uint32_t d = 0; d < n_dims; d++) {
+            (void)fread(&tm.dims[d], 8, 1, f);
+        }
+        uint32_t ttype = 0; (void)fread(&ttype, 4, 1, f);
+        tm.ttype = ttype;
+        (void)fread(&tm.offset, 8, 1, f);
+
+        size_t n_elements = 1;
+        for (auto d : tm.dims) n_elements *= d;
+        tm.n_bytes = gguf_type_bytes(ttype, n_elements);
+
+        tensors.push_back(std::move(tm));
+    }
+
+    // Data section starts at next alignment boundary
+    size_t data_start = ((size_t)ftell(f) + alignment - 1) & ~(size_t)(alignment - 1);
+    fclose(f);
+
+    // Open the GGUF for io_uring reads
+    src->fd = open(gguf_path, O_RDONLY);
+    if (src->fd < 0) {
+        fprintf(stderr, "moe-flash: cannot open GGUF for reading: %s\n", gguf_path);
+        return false;
+    }
+    src->path = gguf_path;
+
+    // Build expert offset map from tensor metadata
+    // Expert tensors follow the pattern: blk.N.ffn_{gate,up,down}_exps.weight
+    // Shape: [inner_dims..., n_experts] — expert is last dimension
+    std::map<int, std::map<std::string, tensor_meta *>> by_layer;
+
+    for (auto & tm : tensors) {
+        if (tm.name.find("_exps") == std::string::npos) continue;
+        // Parse layer: "blk.N.ffn_*_exps.weight"
+        size_t dot1 = tm.name.find('.');
+        size_t dot2 = tm.name.find('.', dot1 + 1);
+        if (dot1 == std::string::npos || dot2 == std::string::npos) continue;
+        int layer = atoi(tm.name.c_str() + dot1 + 1);
+
+        // Determine type: gate, up, down, or gate_up
+        std::string type;
+        if (tm.name.find("gate_up_exps") != std::string::npos) type = "gate_up";
+        else if (tm.name.find("gate_exps") != std::string::npos) type = "gate";
+        else if (tm.name.find("up_exps") != std::string::npos) type = "up";
+        else if (tm.name.find("down_exps") != std::string::npos) type = "down";
+        else continue;
+
+        by_layer[layer][type] = &tm;
+    }
+
+    // Build layer entries
+    for (auto & [layer_idx, types] : by_layer) {
+        gguf_layer_source ls;
+        ls.layer_idx = layer_idx;
+
+        // Determine n_experts from the last dimension of any expert tensor
+        int n_experts = 0;
+        for (auto & [type, tm] : types) {
+            if (!tm->dims.empty()) {
+                n_experts = (int)tm->dims.back();
+                break;
+            }
+        }
+        ls.n_experts = n_experts;
+        ls.experts.resize(n_experts);
+
+        // For each expert, collect individual tensor parts (gate, up, down)
+        for (int e = 0; e < n_experts; e++) {
+            gguf_expert_region region;
+            region.total_size = 0;
+
+            for (auto & [type, tm] : types) {
+                size_t inner_elements = 1;
+                for (size_t d = 0; d + 1 < tm->dims.size(); d++) {
+                    inner_elements *= tm->dims[d];
+                }
+                size_t expert_stride = gguf_type_bytes(tm->ttype, inner_elements);
+                size_t abs_offset = data_start + tm->offset + (size_t)e * expert_stride;
+
+                region.parts.push_back({abs_offset, expert_stride});
+                region.total_size += expert_stride;
+            }
+
+            ls.experts[e] = std::move(region);
+        }
+
+        src->layer_idx_to_pos[layer_idx] = (int)src->layers.size();
+        src->layers.push_back(std::move(ls));
+    }
+
+    fprintf(stderr, "moe-flash: loaded GGUF source: %zu MoE layers, %d experts/layer, data_start=%zu\n",
+            src->layers.size(),
+            src->layers.empty() ? 0 : src->layers[0].n_experts,
+            data_start);
+
+    return !src->layers.empty();
+}
+
