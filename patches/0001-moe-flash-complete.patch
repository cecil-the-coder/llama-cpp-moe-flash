+    pf->n_pending = submitted;
+    pf->pending_layer = layer_idx;
+    pf->n_submits++;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_submit_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Wait for all pending reads to complete
+static void iouring_prefetcher_wait(iouring_prefetcher * pf) {
+    if (pf->n_pending == 0) return;
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    struct io_uring_cqe * cqe;
+    for (int i = 0; i < pf->n_pending; i++) {
