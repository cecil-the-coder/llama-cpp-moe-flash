From 59501d0daa5deccfa8ce939223dcd145e8e262b5 Mon Sep 17 00:00:00 2001
From: moe-flash <moe-flash@localhost>
Date: Tue, 24 Mar 2026 08:22:15 +0000
Subject: [PATCH 12/12] llama-model: disable mmap prefetch when model exceeds
 available memory

The model loader calls posix_madvise(MADV_WILLNEED) on the entire
mmap'd file, paging in all data into the page cache. For models
larger than RAM (e.g., 228 GB on 125 GB), this causes OOM.

Check MemAvailable from /proc/meminfo and skip prefetch when the
total model size exceeds it. Expert data is then paged in on demand
during inference, which works correctly with --cpu-moe since only
the selected experts (e.g., 8/256 = 3%) are accessed per token.
---
 src/llama-model.cpp | 32 +++++++++++++++++++++++++++++++-
 1 file changed, 31 insertions(+), 1 deletion(-)

diff --git a/src/llama-model.cpp b/src/llama-model.cpp
index a458a441a..3da3c9574 100644
--- a/src/llama-model.cpp
+++ b/src/llama-model.cpp
@@ -7489,7 +7489,37 @@ bool llama_model::load_tensors(llama_model_loader & ml) {
 
     ml.done_getting_tensors();
 
-    ml.init_mappings(true, use_mlock ? &pimpl->mlock_mmaps : nullptr);
+    // Disable mmap prefetch if model is larger than available memory.
+    // Prefetching pages in the entire model, which OOMs for models > RAM.
+    // With --cpu-moe, experts stay mmap'd and are paged in on demand.
+    bool do_prefetch = true;
+    {
+        size_t model_size = 0;
+        for (const auto & file : ml.files) {
+            model_size += file->size();
+        }
+        size_t mem_available = 0;
+#if defined(__linux__)
+        // Read MemAvailable from /proc/meminfo
+        FILE * meminfo = fopen("/proc/meminfo", "r");
+        if (meminfo) {
+            char line[256];
+            while (fgets(line, sizeof(line), meminfo)) {
+                if (strncmp(line, "MemAvailable:", 13) == 0) {
+                    mem_available = strtoull(line + 13, nullptr, 10) * 1024; // kB to bytes
+                    break;
+                }
+            }
+            fclose(meminfo);
+        }
+#endif
+        if (mem_available > 0 && model_size > mem_available) {
+            LLAMA_LOG_INFO("%s: model size (%.1f GiB) exceeds available memory (%.1f GiB), disabling mmap prefetch\n",
+                    __func__, model_size / (1024.0 * 1024.0 * 1024.0), mem_available / (1024.0 * 1024.0 * 1024.0));
+            do_prefetch = false;
+        }
+    }
+    ml.init_mappings(do_prefetch, use_mlock ? &pimpl->mlock_mmaps : nullptr);
     pimpl->mappings.reserve(ml.mappings.size());
 
     // create the backend buffers
