+    const size_t headroom = 8ull * 1024 * 1024 * 1024; // 8 GB for KV cache + compute
+    if (size + headroom > free_mem) {
+        VK_LOG_DEBUG("ggml_backend_vk_device_buffer_from_host_ptr: size " << size/(1024*1024) << " MiB exceeds free " << free_mem/(1024*1024) << " MiB (headroom " << headroom/(1024*1024) << " MiB), skipping import");
+        return {};
