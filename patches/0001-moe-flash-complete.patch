+        // Wait for a signal that inference is active
+        int sig = ctx->prefetch_signal.load(std::memory_order_relaxed);
+        if (sig == last_signal) {
+            std::this_thread::sleep_for(std::chrono::milliseconds(1));
+            continue;
+        }
+        last_signal = sig;
+
+        // Cycle through all MoE layers, advising 2-3 layers at a time
+        for (size_t li = 0; li < ctx->gguf_src.layers.size(); li++) {
+            if (!ctx->prefetch_running.load(std::memory_order_relaxed)) break;
+
+            const gguf_layer_source & ls = ctx->gguf_src.layers[li];
+            for (int e = 0; e < ls.n_experts; e++) {
+                const gguf_expert_region & region = ls.experts[e];
