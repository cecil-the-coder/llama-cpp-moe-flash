+if (GGML_IOURING)
+    find_library(URING_LIB uring)
+    if (URING_LIB)
+        target_compile_definitions(llama PRIVATE GGML_USE_IOURING)
+        target_link_libraries(llama PRIVATE ${URING_LIB})
+        message(STATUS "io_uring support enabled for MoE flash streaming")
+    else()
+        message(WARNING "GGML_IOURING=ON but liburing not found")
+    endif()
+endif()
+
 if (BUILD_SHARED_LIBS)
     set_target_properties(llama PROPERTIES POSITION_INDEPENDENT_CODE ON)
     target_compile_definitions(llama PRIVATE LLAMA_BUILD)
