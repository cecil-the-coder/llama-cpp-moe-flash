+// ── MoE Flash: expert streaming with io_uring ──────────────────────────
+//
+// When enabled (via environment variable LLAMA_FLASH_MOE_ENABLED=1), this
+// module installs an eval callback that:
+//
+//   Phase 1 (P2.2): Logs routing decisions (which experts are selected)
+//   Phase 2 (P2.3): Issues posix_fadvise(WILLNEED) for next-layer experts
+//   Phase 3 (P2.4): Issues io_uring reads into staging buffers
+//
+// The eval callback intercepts the "ffn_moe_topk" tensor after argsort
+// completes, reads the selected expert IDs (via ggml_backend_tensor_get
+// on UMA), and triggers prefetch for the next layer's experts.
+
+struct llama_moe_flash_context;
+
+// Initialize the flash MoE context. Returns nullptr if disabled or on error.
+// experts_dir: path to the directory containing split expert files + manifest.json
+// If experts_dir is NULL, reads from LLAMA_FLASH_MOE_EXPERTS_DIR env var.
+// If that is also unset, only routing logging is enabled (no prefetch).
+struct llama_moe_flash_context * llama_moe_flash_init(const char * experts_dir);
+
+// Free the flash MoE context.
+void llama_moe_flash_free(struct llama_moe_flash_context * ctx);
+
+// Get the eval callback function to install on llama_context_params.
+ggml_backend_sched_eval_callback llama_moe_flash_get_callback(void);
+
+// Get the context pointer to pass as cb_eval_user_data.
+void * llama_moe_flash_get_user_data(struct llama_moe_flash_context * ctx);
+
+#ifdef __cplusplus
+}
+#endif
