+#if defined(DATA_A_TQ2_KV)
+#define BLOCK_SIZE QUANT_K_TQ2_KV
+#define BLOCK_BYTE_SIZE 34
+// TQ2_KV dequantize4: iqs is element index within block (multiple of 4, range 0..124).
+// 4 consecutive elements occupy exactly 1 byte of qs[]:
+//   byte_idx = iqs / 4  (0..31, stored as 16 uint16s in packed16)
+//   within that byte: bits [1:0]=elem0, [3:2]=elem1, [5:4]=elem2, [7:6]=elem3
+//   value = (q - 1.5) * d,  q in {0,1,2,3}
+FLOAT_TYPEV4 dequantize4(uint ib, uint iqs, uint a_offset, uint binding_idx) {
+    // byte_idx = iqs / 4; packed16 word = byte_idx / 2 = iqs / 8
+    // byte position within the uint16 word: low=(byte_idx%2==0), high=(byte_idx%2==1)
+    const uint word_idx  = iqs / 8;
+    const uint byte_shift = ((iqs / 4) % 2u) * 8u;  // 0 for low byte, 8 for high byte
+
+    uint b_k, b_v;
+    FLOAT_TYPE d_k, d_v;
+    if (binding_idx == BINDING_IDX_K) {
+        b_k = (uint(k_packed.k_data_packed16[a_offset + ib].qs[word_idx]) >> byte_shift) & 0xFFu;
+        d_k = FLOAT_TYPE(k_packed.k_data_packed16[a_offset + ib].d);
+        const FLOAT_TYPEV4 q = FLOAT_TYPEV4(
+            float((b_k >> 0u) & 3u),
+            float((b_k >> 2u) & 3u),
+            float((b_k >> 4u) & 3u),
+            float((b_k >> 6u) & 3u));
+        return d_k * (q - FLOAT_TYPE(1.5f));
+    } else {
+        b_v = (uint(v_packed.v_data_packed16[a_offset + ib].qs[word_idx]) >> byte_shift) & 0xFFu;
+        d_v = FLOAT_TYPE(v_packed.v_data_packed16[a_offset + ib].d);
+        const FLOAT_TYPEV4 q = FLOAT_TYPEV4(
+            float((b_v >> 0u) & 3u),
+            float((b_v >> 2u) & 3u),
+            float((b_v >> 4u) & 3u),
+            float((b_v >> 6u) & 3u));
+        return d_v * (q - FLOAT_TYPE(1.5f));
+    }
+}
+#endif
