     pf->total_wait_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
 }
 
+// Non-blocking drain: reap any completed CQEs without waiting.
+// Must be called periodically to prevent CQ overflow.
+static int iouring_prefetcher_drain_cqes(iouring_prefetcher * pf) {
+    int reaped = 0;
+    struct io_uring_cqe * cqe;
+    while (io_uring_peek_cqe(&pf->ring, &cqe) == 0) {
+        if (cqe->res >= 0) pf->total_bytes_read += cqe->res;
+        pf->n_pending--;
+        io_uring_cqe_seen(&pf->ring, cqe);
+        reaped++;
+    }
+    return reaped;
+}
