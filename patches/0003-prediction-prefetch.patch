 }
+
+void llama_moe_flash_install_sched_hook(struct llama_moe_flash_context * ctx, ggml_backend_sched_t sched) {
+    if (!ctx || !ctx->enabled || ctx->gguf_src.layers.empty()) return;
+    ggml_backend_sched_set_expert_copy_callback(sched, moe_flash_expert_copy_cb, ctx);
+
+    // Stop the blind background prefetch thread — prediction callback replaces it.
+    // Running both causes I/O contention (kernel readahead fighting targeted fadvise).
+    if (ctx->prefetch_running.load()) {
+        ctx->prefetch_running.store(false);
+        if (ctx->prefetch_thread.joinable()) {
+            ctx->prefetch_thread.join();
+        }
+        fprintf(stderr, "moe-flash: stopped background prefetch thread (replaced by prediction callback)\n");
+    }
+
+#if defined(GGML_USE_IOURING)
+    // Initialize io_uring for the prediction callback if not already done.
+    // The callback uses a small scratch buffer so we only need a lightweight ring
+    // (no staging slots needed — the reads are fire-and-forget for page cache warming).
+    if (!ctx->iouring_pf.ring_initialized) {
+        // Use a minimal slot size since we only read into a 128KB scratch buffer
+        if (iouring_prefetcher_init(&ctx->iouring_pf, 1, 128 * 1024)) {
+            fprintf(stderr, "moe-flash: io_uring ring initialized for prediction callback\n");
+        } else {
+            fprintf(stderr, "moe-flash: io_uring init failed, using posix_fadvise fallback\n");
+        }
+    }
+#endif
+
+    fprintf(stderr, "moe-flash: installed prediction-based expert prefetch\n");
+}
