+// Parse layer index from weight tensor name like "blk.5.ffn_gate_up_exps.weight" → 5
+static int parse_blk_layer_index(const char * name) {
+    const char * blk = strstr(name, "blk.");
+    if (blk) {
+        return atoi(blk + 4);
+    }
+    return -1;
+}
+
 // ── Manifest loader ────────────────────────────────────────────────────
 
 // Minimal JSON parser for manifest.json (avoids external dependency).
@@ -1053,6 +1062,49 @@ static bool moe_flash_eval_cb(struct ggml_tensor * t, bool ask, void * user_data
     return true;
 }
 
+// ── Expert copy callback (prediction-based prefetch) ───────────────────
+//
+// Called by ggml_backend_sched when it copies selected experts for MUL_MAT_ID.
+// We use the current layer's expert selection to prefetch the NEXT layer's
+// experts from the GGUF file via posix_fadvise. This is based on the
+// observation that expert selection has temporal locality across adjacent layers.
+// Prefetches only K/N_expert of the data (e.g., 8/256 = 3%) vs blind prefetch.
+
+static void moe_flash_expert_copy_cb(
+        const struct ggml_tensor * node,
+        const uint32_t * used_ids_bitset,
+        int n_expert,
+        void * user_data) {
+    auto * ctx = (llama_moe_flash_context *)user_data;
+    if (!ctx || !ctx->enabled || ctx->gguf_src.layers.empty()) return;
+
+    // Parse layer index from the weight tensor name (src[0]: "blk.N.ffn_*_exps")
+    int layer_idx = -1;
+    if (node->src[0]) {
+        layer_idx = parse_blk_layer_index(node->src[0]->name);
+    }
+    if (layer_idx < 0) return;
+
+    // Prefetch next layer's selected experts
+#if defined(__linux__)
+    int target_layer = layer_idx + 1;
+    if (target_layer < (int)ctx->gguf_src.layers.size()) {
+        const gguf_layer_source & ls = ctx->gguf_src.layers[target_layer];
+        for (int eid = 0; eid < n_expert && eid < ls.n_experts; eid++) {
+            if (!(used_ids_bitset[eid >> 5] & (1u << (eid & 31)))) continue;
+            for (const auto & part : ls.experts[eid].parts) {
+                posix_fadvise(ls.fd, part.offset, part.size, POSIX_FADV_WILLNEED);
+            }
+        }
+        ctx->n_prefetch_calls++;
+    }
+#else
+    GGML_UNUSED(used_ids_bitset);
+    GGML_UNUSED(n_expert);
+    GGML_UNUSED(node);
+#endif
+}
+
 // ── Public API ─────────────────────────────────────────────────────────
 
 struct llama_moe_flash_context * llama_moe_flash_init(const char * experts_dir) {
@@ -1297,3 +1349,20 @@ void llama_moe_flash_pre_graph(struct llama_moe_flash_context * ctx) {
             break;
     }
 }
+
+void llama_moe_flash_install_sched_hook(struct llama_moe_flash_context * ctx, ggml_backend_sched_t sched) {
+    if (!ctx || !ctx->enabled || ctx->gguf_src.layers.empty()) return;
+    ggml_backend_sched_set_expert_copy_callback(sched, moe_flash_expert_copy_cb, ctx);
+
+    // Stop the blind background prefetch thread — prediction callback replaces it.
+    // Running both causes I/O contention (kernel readahead fighting targeted fadvise).
+    if (ctx->prefetch_running.load()) {
+        ctx->prefetch_running.store(false);
+        if (ctx->prefetch_thread.joinable()) {
+            ctx->prefetch_thread.join();
+        }
+        fprintf(stderr, "moe-flash: stopped background prefetch thread (replaced by prediction callback)\n");
+    }
+
+    fprintf(stderr, "moe-flash: installed prediction-based expert prefetch\n");
+}
