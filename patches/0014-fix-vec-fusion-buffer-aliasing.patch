From e55006a32ef94cb952562854b1f3193330bd5b9c Mon Sep 17 00:00:00 2001
From: Shadow <shadow@code-puppy.dev>
Date: Tue, 31 Mar 2026 03:38:52 +0000
Subject: [PATCH] Fix vec path buffer aliasing with proper range overlap check

---
 ggml/src/ggml-vulkan/ggml-vulkan.cpp | 30 ++++++++++++++++++++++++++++++
 1 file changed, 30 insertions(+)

diff --git a/ggml/src/ggml-vulkan/ggml-vulkan.cpp b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
index e061d4b..b32e451 100644
--- a/ggml/src/ggml-vulkan/ggml-vulkan.cpp
+++ b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
@@ -8588,6 +8588,34 @@ static void ggml_vk_mul_mat_vec_id_q_f16(ggml_backend_vk_context * ctx, vk_conte
         fusion_flags |= MAT_VEC_FUSION_FLAGS_SCALE1;
     }

+    // I10b: Check for actual memory range overlap between IDS and other tensors.
+    // Vulkan suballocator puts many tensors in the same VkBuffer pool, so
+    // comparing buffer handles alone produces false positives. Check byte ranges.
+    auto ranges_overlap = [](const vk_subbuffer & a, const vk_subbuffer & b) -> bool {
+        if (a.buffer != b.buffer) return false;
+        uint64_t a_end = a.offset + a.size;
+        uint64_t b_end = b.offset + b.size;
+        return a.offset < b_end && b.offset < a_end;
+    };
+
+    if (ranges_overlap(d_ids, d_D) || ranges_overlap(d_ids, d_X) || ranges_overlap(d_ids, d_Y)) {
+        fprintf(stderr, "[VEC-FIX] Memory overlap: ids=[%lu+%lu] dst=[%lu+%lu], skip vec\n",
+            (unsigned long)d_ids.offset, (unsigned long)d_ids.size,
+            (unsigned long)d_D.offset, (unsigned long)d_D.size);
+        fflush(stderr);
+        return;
+    }
+
+    // Check fusion buffer overlap with IDS
+    if (ctx->num_additional_fused_ops > 0 && ranges_overlap(d_F0, d_ids)) {
+        fprintf(stderr, "[VEC-FIX] Disabling fusion: d_F0 overlaps d_ids\n");
+        fflush(stderr);
+        fusion_flags = 0;
+        ctx->num_additional_fused_ops = 0;
+        d_F0 = d_D;
+        d_F1 = d_D;
+    }
+
     // Loop over the batch dimension
     for (uint32_t expert_i1 = 0; expert_i1 < nei1; ++expert_i1) {
         const vk_mat_vec_id_push_constants pc = {
--
