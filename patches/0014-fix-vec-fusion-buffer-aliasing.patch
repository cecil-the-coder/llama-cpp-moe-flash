From e55006a32ef94cb952562854b1f3193330bd5b9c Mon Sep 17 00:00:00 2001
From: Shadow <shadow@code-puppy.dev>
Date: Tue, 31 Mar 2026 03:38:52 +0000
Subject: [PATCH] Fix vec path fusion buffer aliasing bug

---
 ggml/src/ggml-vulkan/ggml-vulkan.cpp | 32 ++++++++++++++++++++++++++++
 1 file changed, 32 insertions(+)

diff --git a/ggml/src/ggml-vulkan/ggml-vulkan.cpp b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
index e061d4b..b32e451 100644
--- a/ggml/src/ggml-vulkan/ggml-vulkan.cpp
+++ b/ggml/src/ggml-vulkan/ggml-vulkan.cpp
@@ -8588,6 +8588,31 @@ static void ggml_vk_mul_mat_vec_id_q_f16(ggml_backend_vk_context * ctx, vk_conte
         fusion_flags |= MAT_VEC_FUSION_FLAGS_SCALE1;
     }
 
+    // I10b fix: Check for buffer aliasing. When d_ids aliases with d_D or other
+    // tensors, the expert IDs get corrupted before MUL_MAT_ID can read them.
+    // Skip vec path entirely and use batch path (ggml_vk_mul_mat_id_q_f16)
+    // which has different buffer allocation patterns that avoid this issue.
+    if (d_ids.buffer == d_D.buffer || d_ids.buffer == d_X.buffer || d_ids.buffer == d_Y.buffer) {
+        fprintf(stderr, "[VEC-FIX] Buffer aliasing detected (ids=%p, dst=%p, x=%p, y=%p), skipping vec path\n",
+            (void*)d_ids.buffer.get(), (void*)d_D.buffer.get(),
+            (void*)d_X.buffer.get(), (void*)d_Y.buffer.get());
+        fflush(stderr);
+        // Return early without doing anything - this will cause the graph to
+        // fall back to the batch path for this node
+        return;
+    }
+
+    // I10b fix: Check for buffer aliasing between fusion buffer and IDS buffer.
+    // When d_F0 aliases with d_ids, the shader reads expert IDs as scale values.
+    if (ctx->num_additional_fused_ops > 0 && d_F0.buffer == d_ids.buffer) {
+        fprintf(stderr, "[VEC-FIX] Disabling fusion: d_F0 aliases with d_ids\n");
+        fflush(stderr);
+        fusion_flags = 0;
+        ctx->num_additional_fused_ops = 0;
+        d_F0 = d_D;
+        d_F1 = d_D;
+    }
+
     // I10b debug: log vec path entry to identify crash location
     fprintf(stderr, "[VEC-DBG] mul_mat_vec_id src0=%s(buf=%p nbytes=%zu)"
         " src1=%s(buf=%p) ids=%s(buf=%p nei0=%llu nei1=%llu)"
@@ -8637,6 +8662,13 @@ static bool ggml_vk_use_mul_mat_vec_id(const struct ggml_cgraph * cgraph, int no
     ggml_tensor * dst = cgraph->nodes[node_idx];
     ggml_tensor * src0 = dst->src[0];
     ggml_tensor * src2 = dst->src[2];
+    // I10b fix: Disable vec path for MoE expert tensors to avoid buffer aliasing issues
+    // The gallocr may alias the expert indices buffer with other tensors, causing corruption
+    if (src0->name && (strstr(src0->name, "ffn_gate_exps") || strstr(src0->name, "ffn_up_exps") || strstr(src0->name, "ffn_down_exps"))) {
+        fprintf(stderr, "[VEC-FIX] Disabling vec path for MoE expert tensor: %s\n", src0->name);
+        fflush(stderr);
+        return false;
+    }
     return (src2->ne[1] <= 8) && (src0->type == GGML_TYPE_F32 || src0->type == GGML_TYPE_F16 || ggml_is_quantized(src0->type));
 }
 
