+++ b/ggml/src/ggml-vulkan/vulkan-shaders/copy_to_quant.comp
@@ -184,6 +184,42 @@ void quantize(uint dst_idx, uint src_idx)
 }
 #endif
 
+#if defined(DATA_A_TQ2_KV)
+void quantize(uint dst_idx, uint src_idx)
+{
+    // Pass 1: find max_abs with NaN/Inf guard
+    float max_abs = 0.0;
+    [[unroll]] for (int j = 0; j < QUANT_K_TQ2_KV; ++j) {
+        const float v = data_s[src_idx + j];
+        // NaN/Inf guard: isnan(v) or isinf(v) → treat as 0
+        if (v == v && abs(v) != (1.0/0.0)) {
+            max_abs = max(max_abs, abs(v));
+        }
+    }
+
+    const float d  = (max_abs == 0.0) ? 1.0 : max_abs / 1.5;
+    const float id = 1.0 / d;
+
+    data_q[dst_idx].d = float16_t(d);
+
+    // Pass 2: quantize and pack 4 elements per byte
+    // Element layout: 4 elements packed per byte, byte j contains elements at
+    // positions j, j+32, j+64, j+96 (stride-32 interleave matching the CPU codec)
+    [[unroll]] for (int j = 0; j < 32; ++j) {
+        uint b = 0u;
+        [[unroll]] for (int n = 0; n < 4; ++n) {
+            const float v = data_s[src_idx + j + n * 32];
+            // NaN/Inf guard
+            const float vg = (v == v && abs(v) != (1.0/0.0)) ? v : 0.0;
+            int q = int(round(vg * id + 1.5));
+            q = clamp(q, 0, 3);
+            b |= uint(q) << (n * 2);
+        }
+        data_q[dst_idx].qs[j] = uint8_t(b);
+    }
+}
+#endif
+
