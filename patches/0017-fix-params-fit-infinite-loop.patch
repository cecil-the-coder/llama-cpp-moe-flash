From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Shadow <shadow@code-puppy.dev>
Date: Fri, 04 Apr 2026 12:00:00 +0000
Subject: [PATCH] Disable llama_params_fit (hangs for MoE models)

llama_params_fit binary search loads the full model on each iteration,
hanging for 5-30 min on MoE models. Our auto-detect handles offload.

---
 common/common.cpp | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/common/common.cpp b/common/common.cpp
index 1234567..abcdefg 100644
--- a/common/common.cpp
+++ b/common/common.cpp
@@ -1048,6 +1048,10 @@ common_init_result::common_init_result(common_params & params) :
     auto mparams = common_model_params_to_llama(params);
     auto cparams = common_context_params_to_llama(params);

+    // Disable fitting — binary search hangs for MoE models (loads full model per iteration).
+    // Our auto-detect in llama_params_fit (patch 0001) handles GPU/CPU offload.
+    params.fit_params = false;
+
     if (params.fit_params) {
         LOG_INF("%s: fitting params to device memory, for bugs during this step try to reproduce them with -fit off, or provide --verbose logs if the bug only occurs with -fit on\n", __func__);
         llama_params_fit(params.model.path.c_str(), &mparams, &cparams,
--
