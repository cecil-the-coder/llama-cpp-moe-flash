+// ═════════════════════════════════════════════════════════════════════════════
+// I11: Async Expert Prefetch Implementation
+// ═════════════════════════════════════════════════════════════════════════════
+
+#include <queue>
+#include <mutex>
+#include <condition_variable>
+#include <atomic>
+#include <thread>
+
+// Structure to hold prefetch request
+struct expert_prefetch_req {
+    int layer_id;
+    int expert_id;
+    ggml_backend_t backend;
+    ggml_tensor * expert_tensor;
+};
+
+// Async prefetch queue
+struct async_prefetch_queue {
+    std::queue<expert_prefetch_req> queue;
+    std::mutex mutex;
+    std::condition_variable cv;
+    std::atomic<bool> running{true};
+    std::thread worker;
+    
+    // Stats
+    std::atomic<int64_t> n_prefetched{0};
+    std::atomic<int64_t> n_requests{0};
+    std::atomic<int64_t> n_skipped{0};
+};
+
+// Global prefetch queue (per context)
+static async_prefetch_queue * g_prefetch_queue = nullptr;
+
+// Worker thread function
+static void async_prefetch_worker(async_prefetch_queue * q) {
+    while (q->running.load()) {
+        expert_prefetch_req req;
+        
+        {
+            std::unique_lock<std::mutex> lock(q->mutex);
+            q->cv.wait(lock, [q] { return !q->queue.empty() || !q->running.load(); });
+            
+            if (!q->running.load()) break;
+            if (q->queue.empty()) continue;
+            
+            req = q->queue.front();
+            q->queue.pop();
+        }
+        
+        // Perform async expert copy to GPU
+        // Note: This is a simplified version - real implementation would
+        // use the backend's async copy mechanism
+        
+        // Mark as prefetched
+        q->n_prefetched.fetch_add(1);
+    }
+}
+
+// Initialize async prefetch
+static bool async_prefetch_init() {
+    if (g_prefetch_queue) return true;
+    
+    g_prefetch_queue = new async_prefetch_queue();
+    g_prefetch_queue->worker = std::thread(async_prefetch_worker, g_prefetch_queue);
+    
+    fprintf(stderr, "[I11-ASYNC] Async expert prefetch initialized\n");
+    return true;
+}
+
+// Shutdown async prefetch
+static void async_prefetch_shutdown() {
+    if (!g_prefetch_queue) return;
+    
+    g_prefetch_queue->running.store(false);
+    g_prefetch_queue->cv.notify_all();
+    
+    if (g_prefetch_queue->worker.joinable()) {
+        g_prefetch_queue->worker.join();
+    }
+    
+    fprintf(stderr, "[I11-ASYNC] Stats: requested=%ld, prefetched=%ld, skipped=%ld\n",
+            g_prefetch_queue->n_requests.load(),
+            g_prefetch_queue->n_prefetched.load(),
+            g_prefetch_queue->n_skipped.load());
+    
+    delete g_prefetch_queue;
+    g_prefetch_queue = nullptr;
+}
+
+// Parse layer number from tensor name
+// Handles: "blk.5.ffn_gate_exps.weight" -> 5, "ffn_moe_gate-5" -> 5
+static int parse_layer_id(const char * name) {
+    // Try "blk.N." pattern first
+    const char * p = strstr(name, "blk.");
+    if (p) {
+        return atoi(p + 4);
+    }
+    
+    // Try "ffn_moe_gate-N" pattern (intermediate node names)
+    p = strstr(name, "ffn_moe_gate-");
+    if (p) {
+        return atoi(p + 13);
+    }
+    
+    // Try "ffn_moe_up-N" or "ffn_moe_down-N" patterns
+    p = strstr(name, "ffn_moe_up-");
+    if (p) {
+        return atoi(p + 11);
+    }
+    
+    p = strstr(name, "ffn_moe_down-");
+    if (p) {
+        return atoi(p + 13);
+    }
+    
+    return -1;
+}
+
+// Expert copy callback - called when experts are being copied
+static void expert_copy_callback(
+    const struct ggml_tensor * node,
+    const uint32_t * used_ids_bitset,
+    int n_expert,
+    void * user_data) {
+    
+    auto * ctx = (llama_moe_flash_context *)user_data;
+    if (!ctx || !ctx->enabled) return;
+    
+    // Parse current layer from node name
+    int current_layer = parse_layer_id(node->name);
+    if (current_layer < 0) return;
+    
+    int next_layer = current_layer + 1;
+    
+    // Parse used_ids_bitset to get ACTUAL expert IDs that were used
+    std::vector<int> used_expert_ids;
+    for (int i = 0; i < n_expert; i++) {
+        if (ggml_bitset_get(used_ids_bitset, i)) {
+            used_expert_ids.push_back(i);
+        }
+    }
+    
+    if (used_expert_ids.empty()) return;
+    
+    // Phase 3: Check cache for each used expert
+    if (ctx->cache.max_entries > 0) {
+        int cache_hits = 0;
+        int cache_misses = 0;
+        for (int expert_id : used_expert_ids) {
+            int cache_idx = cache_lookup(ctx->cache, current_layer, expert_id);
+            if (cache_idx >= 0) {
+                cache_hits++;
+                // In full implementation: use cached GPU buffer
+            } else {
+                cache_misses++;
+                // Insert into cache for future use
+                // Note: For now we just track, actual GPU copy would happen here
+            }
+        }
+        if (cache_hits > 0 || cache_misses > 0) {
+            fprintf(stderr, "[I11-CACHE] Layer %d: %d hits, %d misses (%.1f%% hit rate)\n",
+                    current_layer, cache_hits, cache_misses,
+                    100.0 * cache_hits / (cache_hits + cache_misses));
+        }
+    }
+    
+    // Check if we have GGUF source for prefetching
+    if (ctx->gguf_src.fd < 0 || ctx->gguf_src.layers.empty()) {
+        return;  // No GGUF source available
+    }
+    
+    // Find next layer in GGUF source
+    auto it = ctx->gguf_src.layer_idx_to_pos.find(next_layer);
+    if (it == ctx->gguf_src.layer_idx_to_pos.end()) {
+        return;  // Next layer not found (might be last layer)
+    }
+    
+    int layer_pos = it->second;
+    if (layer_pos < 0 || layer_pos >= (int)ctx->gguf_src.layers.size()) {
+        return;
+    }
+    
+    const auto & layer = ctx->gguf_src.layers[layer_pos];
+    
+    // Check if smart prefetch is enabled (default: yes)
+    const char * smart_prefetch_env = getenv("LLAMA_FLASH_MOE_SMART_PREFETCH");
+    bool smart_prefetch = (!smart_prefetch_env || strcmp(smart_prefetch_env, "0") != 0);
+    
+    if (smart_prefetch) {
+        // SMART: Only prefetch the experts that were used in current layer
+        fprintf(stderr, "[I11-SMART] Layer %d: %zu experts used, smart-prefetching %zu experts for layer %d\n",
+                current_layer, used_expert_ids.size(), used_expert_ids.size(), next_layer);
+        
+        // Check if io_uring is available and enabled
+#if defined(GGML_USE_IOURING)
+        bool use_iouring = ctx->iouring_pf.ring_initialized;
+        
+        if (use_iouring) {
+            // Use io_uring for actual async I/O
+            // Convert vector to array for the io_uring function
+            std::vector<int32_t> expert_ids_32(used_expert_ids.begin(), used_expert_ids.end());
+            
+            // Submit async reads for next layer's experts
+            iouring_prefetcher_submit_gguf(
+                &ctx->iouring_pf,
+                ctx->gguf_src,
+                next_layer,
+                expert_ids_32.data(),
+                (int)expert_ids_32.size()
+            );
+            
+            // Note: We DON'T wait here - let reads happen in background while GPU computes!
+            // The pre_graph call will wait before the data is needed
+            
+            fprintf(stderr, "[I11-SMART] Submitted %zu async io_uring reads for layer %d\n",
+                    used_expert_ids.size(), next_layer);
+        } else
+#endif
+        {
+            // Fallback to posix_fadvise (just hints, no actual async I/O)
+            int prefetch_count = 0;
+            int fd = layer.fd >= 0 ? layer.fd : ctx->gguf_src.fd;
+            size_t total_prefetched_bytes = 0;
+            
+            for (int expert_id : used_expert_ids) {
+                if (expert_id < 0 || expert_id >= (int)layer.experts.size()) continue;
+                
+                const auto & expert = layer.experts[expert_id];
+                if (expert.total_size == 0 || expert.parts.empty()) continue;
+                
+                size_t first_offset = expert.parts[0].offset;
+                size_t total_size = expert.total_size;
+                
+                if (fd >= 0 && first_offset > 0 && total_size > 0) {
+                    size_t prefetch_offset = first_offset & ~(4096 - 1);
+                    size_t prefetch_len = total_size + (first_offset - prefetch_offset);
+                    
+                    int ret = posix_fadvise(fd, prefetch_offset, prefetch_len, POSIX_FADV_WILLNEED);
+                    if (ret == 0) {
+                        prefetch_count++;
+                        total_prefetched_bytes += total_size;
+                    }
+                }
+            }
+            
+            fprintf(stderr, "[I11-SMART] Prefetched %d/%zu experts (%zu MB) for layer %d (posix_fadvise)\n",
+                    prefetch_count, used_expert_ids.size(), total_prefetched_bytes / (1024*1024), next_layer);
+        }
+    } else {
+        // AGGRESSIVE: Prefetch ALL experts in next layer (original behavior)
+        fprintf(stderr, "[I11-ASYNC] Layer %d: %zu experts used, prefetching ALL %zu experts for layer %d\n",
+                current_layer, used_expert_ids.size(), layer.experts.size(), next_layer);
+        
+        int prefetch_count = 0;
+        int fd = layer.fd >= 0 ? layer.fd : ctx->gguf_src.fd;
+        
+        for (const auto & expert : layer.experts) {
+            if (expert.total_size == 0 || expert.parts.empty()) continue;
+            
+            size_t first_offset = expert.parts[0].offset;
+            size_t total_size = expert.total_size;
+            
+            if (fd >= 0 && first_offset > 0 && total_size > 0) {
+                size_t prefetch_offset = first_offset & ~(4096 - 1);
+                size_t prefetch_len = total_size + (first_offset - prefetch_offset);
+                
+                int ret = posix_fadvise(fd, prefetch_offset, prefetch_len, POSIX_FADV_WILLNEED);
+                if (ret == 0) {
+                    prefetch_count++;
+                }
+            }
+        }
+        
+        fprintf(stderr, "[I11-ASYNC] Prefetched %d/%zu experts for layer %d\n",
+                prefetch_count, layer.experts.size(), next_layer);
+    }
+    
+    // Update stats
+    if (g_prefetch_queue) {
+        g_prefetch_queue->n_requests.fetch_add(1);
+        g_prefetch_queue->n_prefetched.fetch_add(used_expert_ids.size());
+    }
+}
+
+// Check if expert copy callback is needed
+bool llama_moe_flash_needs_expert_copy_callback(struct llama_moe_flash_context * ctx) {
+    (void)ctx;
+    const char * mode = getenv("LLAMA_FLASH_MOE_MODE");
+    if (mode && strcmp(mode, "async_prefetch") == 0) {
+        return async_prefetch_init();
+    }
+    return false;
+}
+
+// Get the expert copy callback
+ggml_backend_sched_expert_copy_callback llama_moe_flash_get_expert_copy_callback(void) {
+    return expert_copy_callback;
+}
