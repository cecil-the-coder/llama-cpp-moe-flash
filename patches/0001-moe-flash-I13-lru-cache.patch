+
+// Maps (layer, expert) to regions in the original GGUF file.
+// Reading these regions via io_uring warms the page cache so that
+// the mmap'd tensor access doesn't cause major page faults.
+struct gguf_expert_part {
+    size_t offset;   // absolute file offset in the GGUF
+    size_t size;     // bytes to read
+};
+
+struct gguf_expert_region {
+    std::vector<gguf_expert_part> parts; // gate, up, down tensor slices
+    size_t total_size;                    // sum of all parts
+};
+
+struct gguf_layer_source {
+    int layer_idx;
+    int fd;        // file descriptor for the GGUF shard containing this layer
+    int n_experts;
+    std::vector<gguf_expert_region> experts; // indexed by expert_id
+};
+
+struct gguf_source {
+    int         fd;        // open file descriptor for first shard
+    std::string path;
+    std::vector<gguf_layer_source> layers;
+    std::unordered_map<int, int> layer_idx_to_pos;
+    std::vector<int> extra_fds; // fds for additional shards
+};
+
+// ── Manifest types ─────────────────────────────────────────────────────
+
+struct expert_part {
+    std::string name;     // "gate", "up", "down", or "gate_up"
+    size_t      offset;   // offset within the expert file
+    size_t      size;     // bytes
+};
+
+struct expert_entry {
+    int         id;
+    std::string file;
+    size_t      raw_size;
+    size_t      padded_size;
+    std::vector<expert_part> parts;
+    int         fd;       // open file descriptor (for prefetch)
+};
+
+struct layer_entry {
+    int layer_idx;
+    int n_experts;
+    std::vector<expert_entry> experts;
+};
+
+// ── io_uring staging pool ──────────────────────────────────────────────
+
+#if defined(GGML_USE_IOURING)
+
+#define MOE_FLASH_MAX_EXPERTS_PER_TOKEN 16  // max K (top-k) per token
+#define MOE_FLASH_STAGING_ALIGN (2 * 1024 * 1024)  // 2 MB alignment for O_DIRECT
+
+struct iouring_staging_slot {
+    void *  data;           // 2MB-aligned host pointer
+    size_t  capacity;       // allocated size
+    int     expert_id;      // which expert is loaded here (-1 = empty)
+    int     layer;          // which layer
+};
+
+struct iouring_prefetcher {
+    struct io_uring ring;
+    bool            ring_initialized;
+
+    // Staging slots — one set for active reads
+    std::vector<iouring_staging_slot> slots;
+    int n_slots;
+
+    // Pending read tracking
+    int     n_pending;
+    int     pending_layer;
+    int32_t pending_ids[MOE_FLASH_MAX_EXPERTS_PER_TOKEN];
+
+    // Timing stats
+    int64_t total_submit_ns;
+    int64_t total_wait_ns;
+    int64_t n_submits;
+    int64_t n_waits;
+    int64_t total_bytes_read;
+};
+
+static bool iouring_prefetcher_init(iouring_prefetcher * pf, int n_slots, size_t max_expert_size) {
+    memset(pf, 0, sizeof(*pf));
+    pf->n_slots = n_slots;
+    pf->ring_initialized = false;
+
+    // Initialize io_uring
+    // Try SQPOLL first (lower latency), then normal mode, then smaller queue
+    int ret = -1;
+    struct io_uring_params params = {};
+
+    // Attempt 1: SQPOLL (needs CAP_SYS_NICE or root)
+    params.flags = IORING_SETUP_SQPOLL;
+    params.sq_thread_idle = 2000;
+    ret = io_uring_queue_init_params(32, &pf->ring, &params);
+
+    if (ret < 0) {
+        // Attempt 2: normal mode, moderate queue
+        fprintf(stderr, "moe-flash: SQPOLL init failed (%d), trying normal mode\n", -ret);
+        ret = io_uring_queue_init(32, &pf->ring, 0);
+    }
+
+    if (ret < 0) {
+        // Attempt 3: minimal queue (may work with low memlock limits)
+        fprintf(stderr, "moe-flash: normal init failed (%d), trying minimal queue\n", -ret);
+        ret = io_uring_queue_init(8, &pf->ring, 0);
+    }
+
+    if (ret < 0) {
+        fprintf(stderr, "moe-flash: io_uring init failed: %d (check ulimit -l, currently %d KB)\n",
+                -ret, (int)(sysconf(_SC_MEMLOCK) / 1024));
+        fprintf(stderr, "moe-flash: hint: increase memlock with 'ulimit -l unlimited' or set "
+                "LimitMEMLOCK=infinity in container security context\n");
+        return false;
+    }
+    pf->ring_initialized = true;
+    fprintf(stderr, "moe-flash: io_uring ring created (sq_entries=%u)\n", params.sq_entries);
+
+    // Allocate staging slots with aligned memory
+    size_t alloc_size = (max_expert_size + MOE_FLASH_STAGING_ALIGN - 1) & ~(size_t)(MOE_FLASH_STAGING_ALIGN - 1);
+    pf->slots.resize(n_slots);
+
+    for (int i = 0; i < n_slots; i++) {
+        void * ptr = nullptr;
+        if (posix_memalign(&ptr, MOE_FLASH_STAGING_ALIGN, alloc_size) != 0) {
+            fprintf(stderr, "moe-flash: posix_memalign failed for slot %d\n", i);
+            return false;
+        }
+        pf->slots[i].data = ptr;
+        pf->slots[i].capacity = alloc_size;
+        pf->slots[i].expert_id = -1;
+        pf->slots[i].layer = -1;
+    }
+
+    // Register buffers for zero-copy fixed reads
+    std::vector<struct iovec> iovs(n_slots);
+    for (int i = 0; i < n_slots; i++) {
+        iovs[i].iov_base = pf->slots[i].data;
+        iovs[i].iov_len = alloc_size;
+    }
+    ret = io_uring_register_buffers(&pf->ring, iovs.data(), n_slots);
+    if (ret < 0) {
+        fprintf(stderr, "moe-flash: buffer registration failed (%d), using non-fixed reads\n", -ret);
+        // Non-fatal: we'll use regular reads instead of fixed
+    }
+
+    fprintf(stderr, "moe-flash: io_uring initialized: %d slots × %zu bytes (%zu MB total)\n",
+            n_slots, alloc_size, (size_t)n_slots * alloc_size / (1024 * 1024));
+
+    return true;
+}
+
+static void iouring_prefetcher_destroy(iouring_prefetcher * pf) {
+    if (pf->ring_initialized) {
+        io_uring_queue_exit(&pf->ring);
+        pf->ring_initialized = false;
+    }
+    for (auto & slot : pf->slots) {
+        if (slot.data) {
+            free(slot.data);
+            slot.data = nullptr;
+        }
+    }
+}
+
+// Submit async reads for selected experts in the given layer
+// Submit reads from split expert files into staging buffers
+static void iouring_prefetcher_submit(
+        iouring_prefetcher * pf,
+        const std::vector<layer_entry> & layers,
+        const std::unordered_map<int, int> & layer_idx_to_pos,
+        int layer_idx,
+        const int32_t * expert_ids,
+        int k) {
+    auto it = layer_idx_to_pos.find(layer_idx);
+    if (it == layer_idx_to_pos.end()) return;
+
+    const layer_entry & le = layers[it->second];
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    int submitted = 0;
+    for (int i = 0; i < k && i < pf->n_slots; i++) {
+        int eid = expert_ids[i];
+        if (eid < 0 || eid >= le.n_experts) continue;
+
+        const expert_entry & ee = le.experts[eid];
+        if (ee.fd < 0) continue;
+
+        iouring_staging_slot & slot = pf->slots[i];
+
+        struct io_uring_sqe * sqe = io_uring_get_sqe(&pf->ring);
+        if (!sqe) {
+            fprintf(stderr, "moe-flash: no SQE available\n");
+            break;
+        }
+
+        io_uring_prep_read(sqe, ee.fd, slot.data, ee.raw_size, 0);
+        io_uring_sqe_set_data(sqe, (void *)(uintptr_t)i);
+
+        slot.expert_id = eid;
+        slot.layer = layer_idx;
+        pf->pending_ids[submitted] = eid;
+        submitted++;
+    }
+
+    if (submitted > 0) {
+        io_uring_submit(&pf->ring);
+    }
+
+    pf->n_pending = submitted;
+    pf->pending_layer = layer_idx;
+    pf->n_submits++;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_submit_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Submit reads from original GGUF file to warm page cache.
+// The data goes into staging buffers (which we discard), but the side effect
+// is that the kernel populates the page cache for these GGUF regions.
+// When the mmap'd tensor is subsequently accessed by the Vulkan shader,
+// the data is already in page cache → no major faults.
+static void iouring_prefetcher_submit_gguf(
+        iouring_prefetcher * pf,
+        const gguf_source & src,
+        int layer_idx,
+        const int32_t * expert_ids,
+        int k) {
+    auto it = src.layer_idx_to_pos.find(layer_idx);
+    if (it == src.layer_idx_to_pos.end()) return;
+
+    const gguf_layer_source & ls = src.layers[it->second];
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    // Submit one io_uring read per tensor part per expert.
+    // Each part (gate, up, down) is a separate contiguous region in the GGUF.
+    // The reads go into staging buffers (which are discarded), but the side
+    // effect is that the kernel populates the page cache for these regions.
+    int submitted = 0;
+    int slot_idx = 0;
+    for (int i = 0; i < k; i++) {
+        int eid = expert_ids[i];
+        if (eid < 0 || eid >= ls.n_experts) continue;
+
+        const gguf_expert_region & region = ls.experts[eid];
+
+        for (const auto & part : region.parts) {
+            if (slot_idx >= pf->n_slots) break;
+
+            iouring_staging_slot & slot = pf->slots[slot_idx % pf->n_slots];
+            size_t read_size = std::min(part.size, slot.capacity);
+
+            struct io_uring_sqe * sqe = io_uring_get_sqe(&pf->ring);
+            if (!sqe) goto done_submit;
+
+            io_uring_prep_read(sqe, src.fd, slot.data, read_size, part.offset);
+            io_uring_sqe_set_data(sqe, (void *)(uintptr_t)submitted);
+            submitted++;
+        }
+
+        pf->pending_ids[slot_idx] = eid;
+        slot_idx++;
+    }
+
+done_submit:
+    if (submitted > 0) {
+        io_uring_submit(&pf->ring);
+    }
+
+    pf->n_pending = submitted;
+    pf->pending_layer = layer_idx;
+    pf->n_submits++;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_submit_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Wait for all pending reads to complete
+static void iouring_prefetcher_wait(iouring_prefetcher * pf) {
+    if (pf->n_pending == 0) return;
+
+    auto t_start = std::chrono::steady_clock::now();
+
+    struct io_uring_cqe * cqe;
+    for (int i = 0; i < pf->n_pending; i++) {
+        int ret = io_uring_wait_cqe(&pf->ring, &cqe);
+        if (ret < 0) {
+            fprintf(stderr, "moe-flash: io_uring wait failed: %d\n", -ret);
+            break;
+        }
+        if (cqe->res < 0) {
+            fprintf(stderr, "moe-flash: read failed for slot %llu: %d\n",
+                    (unsigned long long)(unsigned long long)(uintptr_t)io_uring_cqe_get_data(cqe), cqe->res);
+        } else {
+            pf->total_bytes_read += cqe->res;
+        }
+        io_uring_cqe_seen(&pf->ring, cqe);
+    }
+
+    pf->n_waits++;
+    pf->n_pending = 0;
+
+    auto t_end = std::chrono::steady_clock::now();
+    pf->total_wait_ns += std::chrono::duration_cast<std::chrono::nanoseconds>(t_end - t_start).count();
+}
+
+// Non-blocking poll for completed reads
+static void iouring_prefetcher_poll(iouring_prefetcher * pf) {
+    if (pf->n_pending == 0) return;
+
+    struct io_uring_cqe * cqe;
+    int completed = 0;
+    
+    // Process all completed reads without blocking
+    while (io_uring_peek_cqe(&pf->ring, &cqe) == 0) {
+        if (cqe->res < 0) {
+            fprintf(stderr, "moe-flash: read failed for slot %llu: %d\n",
+                    (unsigned long long)(uintptr_t)io_uring_cqe_get_data(cqe), cqe->res);
+        } else {
+            pf->total_bytes_read += cqe->res;
+        }
+        io_uring_cqe_seen(&pf->ring, cqe);
+        completed++;
+    }
+    
+    pf->n_pending -= completed;
+}
+
+#endif // GGML_USE_IOURING
+
+// ── Mode enum ─────────────────────────────────────────────────────────
+
+enum moe_flash_mode {
+    MOE_FLASH_MODE_CALLBACK,   // eval callback (accurate but slow — serializes graph)
+    MOE_FLASH_MODE_PREFETCH,   // background madvise thread (zero overhead)
+    MOE_FLASH_MODE_FADVISE,    // pre-graph fadvise on all expert regions (zero overhead)
+};
+
+// ── Flash MoE context ──────────────────────────────────────────────────
+
+
+// ── LRU Cache for GPU Expert Storage ───────────────────────────────────
+
+// Cache entry for a single expert
+struct expert_cache_entry {
+    int layer_idx;           // Which layer this expert belongs to
+    int expert_id;           // Expert ID within the layer
+    void * gpu_buffer;       // GPU memory buffer
+    size_t size;             // Size of expert data in bytes
+    int64_t last_access;     // Timestamp for LRU eviction
+    bool valid;              // Whether this entry contains valid data
+};
+
+// Simple LRU cache for MoE experts in GPU memory
+struct moe_expert_cache {
+    size_t max_size;         // Maximum cache size in bytes
+    size_t current_size;     // Current cache usage in bytes
+    size_t entry_size;       // Size per expert (assumed uniform)
+    int max_entries;         // Maximum number of entries
+    
+    std::vector<expert_cache_entry> entries;  // Cache slots
+    std::unordered_map<uint64_t, int> lookup; // (layer<<16 | expert) -> entry index
+    
+    int64_t access_counter;  // Incrementing counter for LRU
+    int64_t hits;            // Cache hit count
+    int64_t misses;          // Cache miss count
+    int64_t evictions;       // Number of evictions
+    
+    moe_expert_cache() : max_size(0), current_size(0), entry_size(0), 
+                         max_entries(0), access_counter(0), 
+                         hits(0), misses(0), evictions(0) {}
+};
+
+// Generate cache key from layer and expert ID
+static inline uint64_t cache_key(int layer_idx, int expert_id) {
+    return (uint64_t(layer_idx) << 32) | uint64_t(expert_id);
+}
+
+
+// ── Cache Helper Functions ─────────────────────────────────────────────
+
+// Check if expert is in cache
+// Returns: entry index if found, -1 if not found
+static int cache_lookup(moe_expert_cache& cache, int layer_idx, int expert_id) {
+    uint64_t key = cache_key(layer_idx, expert_id);
+    auto it = cache.lookup.find(key);
+    if (it != cache.lookup.end()) {
+        int idx = it->second;
+        if (idx >= 0 && idx < (int)cache.entries.size() && cache.entries[idx].valid) {
+            // Update access time (LRU)
+            cache.entries[idx].last_access = ++cache.access_counter;
+            cache.hits++;
+            return idx;
+        }
+    }
+    cache.misses++;
+    return -1;
+}
+
+// Find least recently used entry for eviction
+// Returns: index of entry to evict
+static int cache_find_lru(moe_expert_cache& cache) {
+    int64_t oldest_access = INT64_MAX;
+    int lru_idx = 0;
+    
+    for (int i = 0; i < (int)cache.entries.size(); i++) {
+        if (!cache.entries[i].valid) {
+            return i;  // Empty slot
+        }
+        if (cache.entries[i].last_access < oldest_access) {
+            oldest_access = cache.entries[i].last_access;
+            lru_idx = i;
+        }
+    }
+    
+    cache.evictions++;
+    return lru_idx;
+}
+
+// Insert expert into cache
+// Returns: entry index where stored, -1 on error
+static int cache_insert(moe_expert_cache& cache, int layer_idx, int expert_id, 
+                        const void * data, size_t size) {
+    if (cache.max_entries == 0) return -1;
+    
+    // Find slot (evict LRU if necessary)
+    int idx = cache_find_lru(cache);
+    
+    // Remove old entry from lookup if valid
+    if (cache.entries[idx].valid) {
+        uint64_t old_key = cache_key(cache.entries[idx].layer_idx, 
+                                     cache.entries[idx].expert_id);
+        cache.lookup.erase(old_key);
+        cache.current_size -= cache.entries[idx].size;
+        // Note: gpu_buffer would be freed here in full implementation
+    }
+    
+    // Store new entry
+    cache.entries[idx].layer_idx = layer_idx;
+    cache.entries[idx].expert_id = expert_id;
+    cache.entries[idx].size = size;
+    cache.entries[idx].last_access = ++cache.access_counter;
+    cache.entries[idx].valid = true;
+    
+    uint64_t new_key = cache_key(layer_idx, expert_id);
+    cache.lookup[new_key] = idx;
+    cache.current_size += size;
+    
+    // In full implementation: copy data to GPU buffer here
+    // For now, just track the metadata
+    
+    return idx;
+}
+
+// Get cache statistics
+static void cache_get_stats(moe_expert_cache& cache, int64_t& hits, int64_t& misses, 
+                            int64_t& evictions) {
+    hits = cache.hits;
+    misses = cache.misses;
+    evictions = cache.evictions;
+}
