+// Forward declarations for dynamic import
+static vk_buffer ggml_vk_buffer_from_host_ptr(vk_device & device, void * ptr, size_t size);
+static void * ggml_backend_vk_buffer_get_base(ggml_backend_buffer_t buffer);
+
+// On UMA, dynamically import a host buffer's memory via VK_EXT_external_memory_host.
+// Once imported, registered in pinned_memory for future host_get lookups.
+static void ggml_vk_dynamic_import_host_buffer(vk_device& device, const ggml_tensor * tensor) {
+    ggml_backend_buffer_t buf = tensor->view_src ? tensor->view_src->buffer : tensor->buffer;
+    if (!buf || !ggml_backend_buffer_is_host(buf)) {
+        return;
+    }
+    // Skip Vulkan-managed host buffers (Vulkan_Host) — they use virtual pointers
+    // (vk_ptr_base + offset) and are already accessible via buf_ctx->dev_buffer.
+    if (buf->iface.get_base == ggml_backend_vk_buffer_get_base) {
+        return;
+    }
+    void * base = ggml_backend_buffer_get_base(buf);
+    size_t size = ggml_backend_buffer_get_size(buf);
+
+    // Check if already imported
+    vk_buffer existing;
+    size_t existing_off;
+    ggml_vk_host_get(device, base, existing, existing_off);
+    if (existing) {
+        return;
+    }
+
+    // Align base down and size up to import alignment
+    const size_t align = device->min_imported_host_pointer_alignment;
+    uintptr_t base_addr = reinterpret_cast<uintptr_t>(base);
+    uintptr_t aligned_addr = base_addr & ~(align - 1);
+    size_t pre_pad = base_addr - aligned_addr;
+    size_t aligned_size = (pre_pad + size + align - 1) & ~(align - 1);
+
+    vk_buffer vk_buf = ggml_vk_buffer_from_host_ptr(device, reinterpret_cast<void *>(aligned_addr), aligned_size);
+    if (vk_buf) {
+        std::lock_guard<std::recursive_mutex> guard(device->mutex);
+        device->pinned_memory.push_back(std::make_tuple(reinterpret_cast<void *>(aligned_addr), aligned_size, vk_buf));
+    }
+}
