From 3e2e0998dfe45d64364ef9172f58fbbc46566d39 Mon Sep 17 00:00:00 2001
From: Shadow <shadow@code-puppy>
Date: Thu, 2 Apr 2026 11:50:54 +0000
Subject: [PATCH] I17: Make metrics server startup async to prevent blocking

---
 src/llama-moe-flash.cpp | 17 +++++++++--------
 1 file changed, 9 insertions(+), 8 deletions(-)

diff --git a/src/llama-moe-flash.cpp b/src/llama-moe-flash.cpp
index 75dd98c..42a4236 100644
--- a/src/llama-moe-flash.cpp
+++ b/src/llama-moe-flash.cpp
@@ -1498,18 +1498,19 @@ struct llama_moe_flash_context * llama_moe_flash_init(const char * experts_dir)
             mode_names[ctx->mode],
             !ctx->gguf_src.layers.empty() ? ctx->gguf_src.path.c_str() : "(none)");
 
-    // I17: Start Prometheus metrics server if port configured
-    fprintf(stderr, "[I17-DEBUG] Checking LLAMA_FLASH_MOE_METRICS_PORT\n");
+    // I17: Start Prometheus metrics server if port configured (async to avoid blocking)
     const char * metrics_port_env = getenv("LLAMA_FLASH_MOE_METRICS_PORT");
-    fprintf(stderr, "[I17-DEBUG] metrics_port_env=%s\n", metrics_port_env ? metrics_port_env : "NULL");
     if (metrics_port_env) {
         int metrics_port = atoi(metrics_port_env);
         if (metrics_port > 0) {
-            if (moe_flash::start_metrics_server(&ctx->metrics, metrics_port)) {
-                fprintf(stderr, "moe-flash: Prometheus metrics on http://localhost:%d/metrics\n", metrics_port);
-            } else {
-                fprintf(stderr, "moe-flash: Failed to start metrics server on port %d\n", metrics_port);
-            }
+            // Start in a detached thread to avoid blocking model loading
+            std::thread metrics_thread([metrics_port, ctx]() {
+                fprintf(stderr, "[I17] Starting metrics server on port %d\n", metrics_port);
+                if (moe_flash::start_metrics_server(&ctx->metrics, metrics_port)) {
+                    fprintf(stderr, "[I17] Metrics server ready on http://localhost:%d/metrics\n", metrics_port);
+                }
+            });
+            metrics_thread.detach();
         }
     }
 
-- 
